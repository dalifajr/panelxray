#!/bin/bash

set -e

if command -v limit-ip >/dev/null 2>&1; then
	exec "$(command -v limit-ip)" sship "$@"
fi

if [[ -x /usr/bin/limit-ip ]]; then
	exec /usr/bin/limit-ip sship "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [[ -x "${SCRIPT_DIR}/limit/limit-ip" ]]; then
	exec "${SCRIPT_DIR}/limit/limit-ip" sship "$@"
fi

echo "limit-ip command tidak ditemukan"
exit 1
