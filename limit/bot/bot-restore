red() { echo -e "\\033[32;1m${*}\\033[0m"; }
IP=$(curl -s ipv4.icanhazip.com 2>/dev/null || wget -qO- ipinfo.io/ip 2>/dev/null || echo "unknown-ip")
HOST=$(cat /etc/xray/domain 2>/dev/null || hostname -f 2>/dev/null || hostname 2>/dev/null || echo "unknown-domain")
DATEVPS=$(date +"%d-%B-%Y")
ISPVPS=$(cat /etc/xray/isp 2>/dev/null || echo "unknown-isp")
CITY=$(cat /etc/xray/city 2>/dev/null || echo "unknown-city")
GREEN="\e[92;1m"
BLUE="\033[36m"
RED='\033[0;31m'
NC='\033[0m'

if [[ -t 0 ]]; then
    read -rp "Please Input Link : " DATAVPS
else
    read -r DATAVPS
fi

function RESTOREVPS() {
    CURRENT_DOMAIN=""
    if [[ -f /etc/xray/domain ]]; then
        CURRENT_DOMAIN=$(cat /etc/xray/domain)
    fi

    cd /root
    rm -rf backup.zip backup
    if ! wget -O backup.zip "$DATAVPS" >/dev/null 2>&1; then
        echo "Gagal mendownload file backup dari link: $DATAVPS"
        exit 1
    fi
    if ! unzip -o backup.zip >/dev/null 2>&1; then
        echo "Gagal mengekstrak file backup"
        rm -rf backup.zip
        exit 1
    fi
    if [[ ! -d /root/backup ]]; then
        echo "Folder /root/backup tidak ditemukan di dalam arsip"
        rm -rf backup.zip
        exit 1
    fi
    
    cp /root/backup/passwd /etc/
    cp /root/backup/group /etc/
    cp /root/backup/shadow /etc/
    cp /root/backup/gshadow /etc/
    cp -r /root/backup/html /var/www/ 2>/dev/null || true
    cp -r /root/backup/kyt /var/lib/ 2>/dev/null || true
    cp -r /root/backup/ssh.db /etc/ssh/.ssh.db 2>/dev/null || true
    cp -r /root/backup/vmess.db /etc/vmess/.vmess.db 2>/dev/null || true
    cp -r /root/backup/vless.db /etc/vless/.vless.db 2>/dev/null || true
    cp -r /root/backup/trojan.db /etc/trojan/.trojan.db 2>/dev/null || true
    cp -r /root/backup/shadowsocks.db /etc/shadowsocks/.shadowsocks.db 2>/dev/null || true
    cp -r /root/backup/*.json /etc/xray >/dev/null 2>&1 || true
    cp -r /root/backup/*.log /etc/xray >/dev/null 2>&1 || true
    cp /etc/openvpn/*.ovpn /var/www/html/ 2>/dev/null || true
    
    cd
    
    # Preserve new domain if it was set
    if [[ -n "$CURRENT_DOMAIN" ]]; then
        echo "$CURRENT_DOMAIN" > /etc/xray/domain
    fi

    # Check if domain changed and renew SSL
    BACKUP_DOMAIN=""
    if [[ -f /root/backup/xray/domain ]]; then
        BACKUP_DOMAIN=$(cat /root/backup/xray/domain)
    fi

    if [[ -n "$CURRENT_DOMAIN" && -n "$BACKUP_DOMAIN" && "$CURRENT_DOMAIN" != "$BACKUP_DOMAIN" ]]; then
        echo "Domain baru terdeteksi: $CURRENT_DOMAIN (sebelumnya $BACKUP_DOMAIN)"
        echo "Memperbarui sertifikat SSL Let's Encrypt secara otomatis..."
        systemctl stop nginx 2>/dev/null || true
        systemctl stop haproxy 2>/dev/null || true
        if [[ ! -f /root/.acme.sh/acme.sh ]]; then
            mkdir -p /root/.acme.sh
            curl -sS https://acme-install.netlify.app/acme.sh -o /root/.acme.sh/acme.sh >/dev/null 2>&1 || true
            chmod +x /root/.acme.sh/acme.sh
            /root/.acme.sh/acme.sh --upgrade --auto-upgrade >/dev/null 2>&1 || true
            /root/.acme.sh/acme.sh --set-default-ca --server letsencrypt >/dev/null 2>&1 || true
        fi
        if [[ -f /root/.acme.sh/acme.sh ]]; then
            /root/.acme.sh/acme.sh --issue -d "$CURRENT_DOMAIN" --standalone -k ec-256 --force >/dev/null 2>&1 || true
            /root/.acme.sh/acme.sh --installcert -d "$CURRENT_DOMAIN" --fullchainpath /etc/xray/xray.crt --keypath /etc/xray/xray.key --ecc >/dev/null 2>&1 || true
            chmod 777 /etc/xray/xray.key >/dev/null 2>&1 || true
            
            # Compile hap.pem for HAProxy
            if [[ -f /etc/xray/xray.crt && -f /etc/xray/xray.key ]]; then
                mkdir -p /etc/haproxy/certs >/dev/null 2>&1 || true
                cat /etc/xray/xray.crt /etc/xray/xray.key > /etc/haproxy/hap.pem 2>/dev/null || true
                chmod 600 /etc/haproxy/hap.pem >/dev/null 2>&1 || true
                cp -f /etc/haproxy/hap.pem /etc/haproxy/certs/default.pem >/dev/null 2>&1 || true
            fi
        fi
    fi

    systemctl restart xray >/dev/null 2>&1 || true
    rm -rf /root/backup.zip /root/backup
    
    echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "SUCCESSFULL RESTORE YOUR VPS"
    echo -e "Please Save The Following Data"
    echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "Your VPS IP : $IP"
    echo -e "DOMAIN      : $HOST"
    echo -e "DATE        : $DATEVPS"
    echo -e "ISP         : $ISPVPS"
    echo -e "LOCATION    : $CITY"
    echo -e "━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "Please Reboot Vps"
}
RESTOREVPS
