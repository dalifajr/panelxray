#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

# Color
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
LIGHT='\033[0;37m'
clear
IS_INTERACTIVE=0
if [ -t 0 ]; then
    IS_INTERACTIVE=1
fi

return_to_menu() {
    local code="${1:-0}"
    if [[ "${IS_INTERACTIVE}" == "1" ]]; then
        read -n 1 -s -r -p "Press any key to back on menu"
        menu
    fi
    exit "$code"
}

update_db_expiry() {
    local db_file="$1"
    local tmp_file
    [[ -f "$db_file" ]] || return 0
    tmp_file="${db_file}.tmp.$$"
    awk -v user="$user" -v exp="$exp4" '{ if ($1 == "###" && $2 == user) { $3 = exp } print }' "$db_file" > "$tmp_file" && mv "$tmp_file" "$db_file"
}

NUMBER_OF_CLIENTS=$(grep -c -E "^#!# " "/etc/xray/config.json")
	if [[ ${NUMBER_OF_CLIENTS} == '0' ]]; then
		clear
        echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
        echo -e "          Renew Shadowsocks       \E[0m"
        echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
		echo ""
		echo "You have no existing clients!"
		echo ""
		echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
        echo ""
        return_to_menu 1
	fi

	clear
	echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
    echo -e "         Renew Shadowsocks         \E[0m"
    echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
    echo ""
  	grep -E "^#!# " "/etc/xray/config.json" | cut -d ' ' -f 2-3 | column -t | sort | uniq
    echo ""
    echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
	read -rp "Input Username : " user
    if [ -z "$user" ]; then
    return_to_menu 1
    else
    if ! grep -qwE "^#!# $user " "/etc/xray/config.json"; then
      if [[ -f "/etc/kyt/suspended/shadowsocks/$user" ]]; then
        unsuspss --user "$user" >/dev/null 2>&1 || true
      fi
    fi
    if ! grep -qwE "^#!# $user " "/etc/xray/config.json"; then
      echo "User not found"
      exit 1
    fi
    read -p "Expired (days): " masaaktif
    read -p "Limit User (IP): " iplim
    if [ -z "${iplim}" ]; then
      iplim="1"
    fi
    mkdir -p /etc/kyt/limit/shadowsocks/ip
    if [[ "${iplim}" =~ ^[0-9]+$ ]] && [[ "${iplim}" -gt 0 ]]; then
      echo "${iplim}" > /etc/kyt/limit/shadowsocks/ip/${user}
    else
      rm -f /etc/kyt/limit/shadowsocks/ip/${user}
    fi
    exp=$(grep -wE "^#!# $user" "/etc/xray/config.json" | cut -d ' ' -f 3 | sort | uniq)
    now=$(date +%Y-%m-%d)
    d1=$(date -d "$exp" +%s)
    d2=$(date -d "$now" +%s)
    exp2=$(( (d1 - d2) / 86400 ))
    exp3=$(($exp2 + $masaaktif))
    exp4=`date -d "$exp3 days" +"%Y-%m-%d"`
    sed -i "/#!# $user/c\#!# $user $exp4" /etc/xray/config.json
    [[ -f /root/akun/shadowsocks/.shadowsocks.conf ]] && sed -i "/#!# $user/c\#!# $user $exp4" /root/akun/shadowsocks/.shadowsocks.conf
    update_db_expiry /etc/shadowsocks/.shadowsocks.db
    systemctl restart xray > /dev/null 2>&1
    clear
    echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
    echo " Shadowsocks Account Was Successfully Renewed"
    echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
    echo ""
    echo " Client Name : $user"
    echo " Expired On  : $exp4"
    echo " User Limit IP: $iplim"
    echo ""
    echo -e "\033[0;33m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
    echo ""
    return_to_menu 0
    fi
