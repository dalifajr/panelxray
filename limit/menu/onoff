#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

clear

RED='\033[0;31m'

badvpn1=$(systemctl status vmip | grep running | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)

# STATUS SERVICE LIMIT IP
if [[ $badvpn1 == "running" ]]; then 
     status_udp1="${GREEN}AKTIF${NC}"
else
     status_udp1="${RED}TIDAK AKTIF${NC}"
fi

if declare -F thm_title >/dev/null; then
    thm_title "MENU LIMIT IP"
    thm_info_row "Status Limit IP" "$status_udp1"
    thm_menu_item 1 "Nonaktifkan Limit IP"
    thm_menu_item 2 "Aktifkan Limit IP"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU LIMIT IP"
    echo "Status Limit IP: $status_udp1"
    echo "1) Nonaktifkan Limit IP"
    echo "2) Aktifkan Limit IP"
    echo "0) Kembali Ke Menu Utama"
fi

read -p "Pilih Menu [ 1 - 2 atau 0 ] : " menu
case $menu in
1)   clear ;
    cd /etc/systemd/system/
    rm -rf /etc/systemd/system/vmip.service
    rm -rf /etc/systemd/system/vlip.service
    rm -rf /etc/systemd/system/trip.service
    systemctl daemon-reload
    reboot
    ;;
2) clear ;
    cat >/etc/systemd/system/vmip.service << EOF
[Unit]
Description=My
After=network.target

[Service]
WorkingDirectory=/root
ExecStart=/usr/bin/limit-ip vmip
Restart=always

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl restart vmip
systemctl enable vmip

cat >/etc/systemd/system/vlip.service << EOF
[Unit]
Description=My
After=network.target

[Service]
WorkingDirectory=/root
ExecStart=/usr/bin/limit-ip vlip
Restart=always

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl restart vlip
systemctl enable vlip

cat >/etc/systemd/system/trip.service << EOF
[Unit]
Description=My
After=network.target

[Service]
WorkingDirectory=/root
ExecStart=/usr/bin/limit-ip trip
Restart=always

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl restart trip
systemctl enable trip
#SERVICE LIMIT QUOTA
reboot
    ;;
0) clear ;
    menu
    ;;
*) clear ;
    menu
    ;;
esac