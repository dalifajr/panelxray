  chmod 600 "${ENV_FILE}"

  echo "${admin_user}" > "${PANEL_ETC_DIR}/admin_user"
  chmod 600 "${PANEL_ETC_DIR}/admin_user"

  msg_ok "Credential panel siap."
}

install_service() {
  msg_info "Mendaftarkan service systemd ${APP_NAME}."
  cat > "${SERVICE_FILE}" <<EOF
[Unit]
Description=VPNXRay MVC Web Panel
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=${APP_ROOT}
EnvironmentFile=${ENV_FILE}
ExecStart=${APP_ROOT}/.venv/bin/gunicorn --workers 2 --bind ${APP_HOST}:${APP_PORT} --timeout 60 app:app
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable --now "${APP_NAME}" >/dev/null 2>&1 || true

  if systemctl is-active --quiet "${APP_NAME}"; then
    msg_ok "Service ${APP_NAME} aktif."
  else
    msg_warn "Service ${APP_NAME} belum aktif, cek log: journalctl -u ${APP_NAME} -n 40"
  fi
}

configure_nginx_route() {
  if [[ ! -f "${NGINX_CONF}" ]]; then
    msg_warn "File nginx conf tidak ditemukan: ${NGINX_CONF}."
    return
  fi

  if grep -q "PANELXRAY-WEB-PANEL-START" "${NGINX_CONF}"; then
    msg_info "Route /panel sudah ada di konfigurasi nginx."
  else
    msg_info "Menambahkan route /panel ke nginx."
    local backup_file temp_file
    backup_file="${NGINX_CONF}.bak.${APP_NAME}.$(date +%s)"
    temp_file="${NGINX_CONF}.tmp"
    cp -f "${NGINX_CONF}" "${backup_file}"

    awk '
      BEGIN { inserted = 0 }
      {
        if (!inserted && $0 ~ /location ~ \/vless/) {
          print "    # PANELXRAY-WEB-PANEL-START"
          print "    location = /panel {"
          print "      return 301 /panel/;"
          print "    }"
          print "    location ^~ /panel/ {"
          print "      proxy_http_version 1.1;"
          print "      proxy_set_header Host \\$host;"
          print "      proxy_set_header X-Real-IP \\$remote_addr;"
          print "      proxy_set_header X-Forwarded-For \\$proxy_add_x_forwarded_for;"
          print "      proxy_set_header X-Forwarded-Proto \\$scheme;"
          print "      proxy_pass http://127.0.0.1:9999;"
          print "    }"
          print "    # PANELXRAY-WEB-PANEL-END"
          inserted = 1
        }
        print
      }
      END {
        if (!inserted) {
          exit 7
        }
      }
    ' "${NGINX_CONF}" > "${temp_file}" || {
      msg_warn "Gagal menyisipkan route /panel otomatis. Backup: ${backup_file}"
      rm -f "${temp_file}"
      return
    }

    mv "${temp_file}" "${NGINX_CONF}"
  fi

  if command -v nginx >/dev/null 2>&1; then
    if nginx -t >/dev/null 2>&1; then
      systemctl restart nginx >/dev/null 2>&1 || msg_warn "Nginx gagal restart."
      msg_ok "Nginx siap melayani path /panel."
    else
      msg_warn "Validasi nginx gagal, cek konfigurasi secara manual."
    fi
  fi
}

set_permissions() {
  chown -R root:root "${APP_ROOT}" "${PANEL_ETC_DIR}" >/dev/null 2>&1 || true
  chmod -R go-rwx "${PANEL_ETC_DIR}" >/dev/null 2>&1 || true
}

show_summary() {
  local admin_user admin_pass domain
  admin_user="$(cat "${PANEL_ETC_DIR}/admin_user" 2>/dev/null || echo admin)"
  admin_pass="$(cat "${PASS_FILE}" 2>/dev/null || echo '(tidak tersedia)')"
  domain="$(cat /etc/xray/domain 2>/dev/null || echo '-')"

  echo
  msg_ok "Instalasi Web Panel MVC selesai."
  echo "--------------------------------------------"
  echo "URL Lokal   : http://${APP_HOST}:${APP_PORT}/panel/"
  echo "URL Domain  : https://${domain}/panel/"
  echo "Username    : ${admin_user}"
  echo "Password    : ${admin_pass}"
  echo "Service     : ${APP_NAME}"
  echo "--------------------------------------------"
  echo "Gunakan menu utility untuk menjalankan ulang installer jika ingin refresh app."
}

main() {
  show_header
  require_root
  install_dependencies
  write_app_files
  setup_python_runtime
  setup_panel_auth
  install_service
  configure_nginx_route
  set_permissions
  show_summary
}

main "$@"
