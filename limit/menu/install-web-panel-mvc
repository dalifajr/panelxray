from datetime import datetime
from pathlib import Path
import os
import shutil
import socket
import subprocess

MANAGED_SERVICES = [
    {"name": "SSH", "unit": "ssh", "fallback": "sshd"},
    {"name": "DROPBEAR", "unit": "dropbear"},
    {"name": "XRAY", "unit": "xray"},
    {"name": "NGINX", "unit": "nginx"},
    {"name": "HAPROXY", "unit": "haproxy"},
    {"name": "WS", "unit": "ws"},
]
ALLOWED_ACTIONS = {"start", "stop", "restart"}


def _read_text(path: str, fallback: str = "-") -> str:
    file_path = Path(path)
    if not file_path.exists():
        return fallback
    value = file_path.read_text(encoding="utf-8", errors="ignore").strip()
    return value if value else fallback


def _service_state(name: str) -> str:
    result = subprocess.run(
        ["systemctl", "is-active", name],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return "ON" if result.returncode == 0 else "OFF"


def _run_service_action(unit: str, action: str) -> bool:
    commands = [
        ["systemctl", action, unit],
        ["service", unit, action],
    ]
    for command in commands:
        result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            return True
    return False


def _uptime_human() -> str:
    uptime_path = Path("/proc/uptime")
    if not uptime_path.exists():
        return "-"

    raw_seconds = float(uptime_path.read_text().split()[0])
    minutes = int(raw_seconds // 60)
    hours, minutes = divmod(minutes, 60)
    days, hours = divmod(hours, 24)

    parts = []
    if days:
        parts.append(f"{days}d")
    if hours:
        parts.append(f"{hours}h")
    parts.append(f"{minutes}m")
    return " ".join(parts)


def _primary_ip() -> str:
    probe = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        probe.connect(("8.8.8.8", 80))
        return probe.getsockname()[0]
    except OSError:
        return "-"
    finally:
        probe.close()


def _read_meminfo_kb():
    meminfo = {}
    meminfo_path = Path("/proc/meminfo")
    if not meminfo_path.exists():
        return meminfo

    for line in meminfo_path.read_text(encoding="utf-8", errors="ignore").splitlines():
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        parts = value.strip().split()
        if not parts:
            continue
        try:
            meminfo[key] = int(parts[0])
        except ValueError:
            continue
    return meminfo


def _load_average() -> str:
    try:
        load1, load5, load15 = os.getloadavg()
        return f"{load1:.2f} {load5:.2f} {load15:.2f}"
    except OSError:
        return "-"


def _established_tcp_count() -> int:
    result = subprocess.run(
        ["ss", "-Hant", "state", "established"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
        text=True,
    )
    if result.returncode != 0:
        return 0
    return len([line for line in result.stdout.splitlines() if line.strip()])


def get_system_summary():
    meminfo = _read_meminfo_kb()
    total_ram_mb = round(meminfo.get("MemTotal", 0) / 1024) if meminfo else 0
    ram_text = f"{total_ram_mb} MB" if total_ram_mb > 0 else "-"

    return {
        "hostname": socket.gethostname(),
        "domain": _read_text("/etc/xray/domain"),
        "isp": _read_text("/etc/xray/isp"),
        "city": _read_text("/etc/xray/city"),
        "ip": _primary_ip(),
        "uptime": _uptime_human(),
        "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "ram": ram_text,
    }


def get_realtime_stats():
    meminfo = _read_meminfo_kb()
    mem_total_kb = meminfo.get("MemTotal", 0)
    mem_available_kb = meminfo.get("MemAvailable", 0)
    mem_used_kb = max(mem_total_kb - mem_available_kb, 0)

    mem_total_mb = round(mem_total_kb / 1024) if mem_total_kb else 0
    mem_used_mb = round(mem_used_kb / 1024) if mem_used_kb else 0
    mem_percent = round((mem_used_kb / mem_total_kb) * 100, 2) if mem_total_kb else 0

    disk_total, disk_used, _disk_free = shutil.disk_usage("/")
    disk_total_gb = round(disk_total / (1024 ** 3), 2)
    disk_used_gb = round(disk_used / (1024 ** 3), 2)
    disk_percent = round((disk_used / disk_total) * 100, 2) if disk_total else 0

    return {
        "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "uptime": _uptime_human(),
        "loadavg": _load_average(),
        "ram_total_mb": mem_total_mb,
        "ram_used_mb": mem_used_mb,
        "ram_percent": mem_percent,
        "disk_total_gb": disk_total_gb,
        "disk_used_gb": disk_used_gb,
        "disk_percent": disk_percent,
        "tcp_established": _established_tcp_count(),
    }


def get_service_statuses():
    result = []
    for service in MANAGED_SERVICES:
        unit = service["unit"]
        state = _service_state(unit)
        active_unit = unit
        fallback = service.get("fallback")

        if state == "OFF" and fallback:
            fallback_state = _service_state(fallback)
            if fallback_state == "ON":
                state = fallback_state
                active_unit = fallback

        result.append(
            {
                "name": service["name"],
                "unit": service["unit"],
                "active_unit": active_unit,
                "state": state,
            }
        )
    return result


def control_service(unit: str, action: str):
    if action not in ALLOWED_ACTIONS:
        raise ValueError("Aksi service tidak valid.")

    service = next((item for item in MANAGED_SERVICES if item["unit"] == unit), None)
    if service is None:
        raise ValueError("Service tidak dikenali.")

    candidates = [service["unit"]]
    fallback = service.get("fallback")
    if fallback:
        candidates.append(fallback)

    for candidate in candidates:
        if _run_service_action(candidate, action):
            return {
                "name": service["name"],
                "unit": candidate,
                "action": action,
                "state": _service_state(candidate),
            }

    raise RuntimeError(f"Gagal menjalankan aksi {action} untuk service {service['name']}.")
