msg_info() {
  echo -e "\033[1;36m[INFO]\033[0m $1"
}

msg_warn() {
  echo -e "\033[1;33m[WARN]\033[0m $1"
}

msg_ok() {
  echo -e "\033[1;32m[OK]\033[0m $1"
}

show_header() {
  clear
  if declare -F thm_title >/dev/null; then
    thm_title "INSTALL WEB PANEL MVC"
    thm_welcome "Material 3 Expressive"
    thm_footer
  else
    echo "============================================"
    echo " INSTALL WEB PANEL MVC (MATERIAL 3)"
    echo "============================================"
  fi
}

require_root() {
  if [[ $EUID -ne 0 ]]; then
    msg_warn "Installer harus dijalankan sebagai root."
    exit 1
  fi
}

install_dependencies() {
  if ! command -v apt-get >/dev/null 2>&1; then
    msg_warn "Sistem tidak mendukung apt-get. Installer dihentikan."
    exit 1
  fi

  msg_info "Menginstall dependency Python runtime."
  apt-get update -y >/dev/null 2>&1 || true
  DEBIAN_FRONTEND=noninteractive apt-get install -y python3 python3-venv python3-pip >/dev/null
}

