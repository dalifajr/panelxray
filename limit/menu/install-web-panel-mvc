from datetime import datetime, timedelta
from pathlib import Path
import os
import re
import shutil
import subprocess
import tempfile
import uuid

XRAY_CONFIG_PATH = Path("/etc/xray/config.json")
XRAY_BACKUP_DIR = Path("/etc/xray/backup-web-panel")
KEEP_BACKUP_COUNT = 30
USERNAME_REGEX = re.compile(r"^[a-zA-Z0-9_]+$")
CREDENTIAL_REGEX = re.compile(r'"(?:id|password)"\s*:\s*"([^"]+)"')

MARKER_TO_PROTOCOL = {
  "#!#": "shadowsocks",
  "###": "vmess",
  "#&": "vless",
  "#!": "trojan",
}

PROTOCOL_RULES = {
  "vmess": {
    "display": "VMESS",
    "marker": "###",
    "anchors": ["#vmess", "#vmessgrpc"],
    "entry_template": '},{"id": "{credential}","alterId": 0,"email": "{username}"',
  },
  "vless": {
    "display": "VLESS",
    "marker": "#&",
    "anchors": ["#vless", "#vlessgrpc"],
    "entry_template": '},{"id": "{credential}","email": "{username}"',
  },
  "trojan": {
    "display": "TROJAN",
    "marker": "#!",
    "anchors": ["#trojanws", "#trojangrpc"],
    "entry_template": '},{"password": "{credential}","email": "{username}"',
  },
  "shadowsocks": {
    "display": "SHADOWSOCKS",
    "marker": "#!#",
    "anchors": ["#ssws", "#ssgrpc"],
    "entry_template": '},{"password": "{credential}","method": "aes-128-gcm","email": "{username}"',
  },
}

SIDE_CAR_DB_PATHS = {
  "vmess": Path("/etc/vmess/.vmess.db"),
  "vless": Path("/etc/vless/.vless.db"),
  "trojan": Path("/etc/trojan/.trojan.db"),
  "shadowsocks": Path("/etc/shadowsocks/.shadowsocks.db"),
}

REQUIRED_ANCHORS = [
  "#vless",
  "#vlessgrpc",
  "#vmess",
  "#vmessgrpc",
  "#trojanws",
  "#trojangrpc",
  "#ssws",
  "#ssgrpc",
]


def _parse_account_line(raw_line: str):
  line = raw_line.strip()
  for marker, protocol in MARKER_TO_PROTOCOL.items():
    prefix = f"{marker} "
    if line.startswith(prefix):
      parts = line.split()
      if len(parts) >= 3:
        return {
          "protocol_key": protocol,
          "protocol": PROTOCOL_RULES[protocol]["display"],
          "username": parts[1],
          "expiry": parts[2],
          "marker": marker,
        }
  return None


def _read_config_lines():
  if not XRAY_CONFIG_PATH.exists():
    raise FileNotFoundError(f"Config Xray tidak ditemukan: {XRAY_CONFIG_PATH}")
  return XRAY_CONFIG_PATH.read_text(encoding="utf-8", errors="ignore").splitlines(keepends=True)


def _validate_username(username: str):
  if not username:
    raise ValueError("Username wajib diisi.")
  if not USERNAME_REGEX.fullmatch(username):
    raise ValueError("Username hanya boleh huruf, angka, dan underscore.")


def _validate_protocol(protocol: str):
  if protocol not in PROTOCOL_RULES:
    raise ValueError("Protocol tidak valid.")


def _normalize_expiry_days(expiry_days):
  try:
    days = int(str(expiry_days).strip())
  except ValueError as exc:
    raise ValueError("Expired (hari) harus berupa angka.") from exc

  if days <= 0 or days > 3650:
    raise ValueError("Expired (hari) harus di antara 1 sampai 3650.")

  return days


def _expiry_from_days(days: int):
  return (datetime.utcnow() + timedelta(days=days)).strftime("%Y-%m-%d")


def _create_backup():
  XRAY_BACKUP_DIR.mkdir(parents=True, exist_ok=True)
  timestamp = datetime.utcnow().strftime("%Y%m%d-%H%M%S-%f")
  backup_path = XRAY_BACKUP_DIR / f"config.json.{timestamp}.bak"
  shutil.copy2(XRAY_CONFIG_PATH, backup_path)

  backups = sorted(XRAY_BACKUP_DIR.glob("config.json.*.bak"))
  while len(backups) > KEEP_BACKUP_COUNT:
    oldest = backups.pop(0)
    try:
      oldest.unlink()
    except OSError:
      break

  return backup_path


def _atomic_write_path(target_path: Path, content: str):
  target_path.parent.mkdir(parents=True, exist_ok=True)
  fd, tmp_path = tempfile.mkstemp(prefix=f"{target_path.name}-", dir=str(target_path.parent))
  try:
    with os.fdopen(fd, "w", encoding="utf-8", newline="\n") as handle:
      handle.write(content)
      handle.flush()
      os.fsync(handle.fileno())
    os.replace(tmp_path, target_path)
  finally:
    if os.path.exists(tmp_path):
      os.unlink(tmp_path)


def _atomic_write(lines):
  content = "".join(lines)
  for anchor in REQUIRED_ANCHORS:
    if anchor not in content:
      raise ValueError(f"Anchor {anchor} hilang, write dibatalkan untuk mencegah korupsi config.")
  _atomic_write_path(XRAY_CONFIG_PATH, content)


def _restart_xray():
  commands = [
    ["systemctl", "restart", "xray"],
    ["service", "xray", "restart"],
  ]
  for command in commands:
    try:
      subprocess.run(command, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
      return True
    except Exception:
      continue
  return False


def _find_anchor_index(lines, anchor):
  for idx, line in enumerate(lines):
    if line.strip().startswith(anchor):
      return idx
  raise ValueError(f"Anchor {anchor} tidak ditemukan di config xray.")


def _username_exists(lines, username):
  for line in lines:
    parsed = _parse_account_line(line)
    if parsed and parsed["username"] == username:
      return True
  return False


def _parse_sidecar_line(raw_line: str):
  parts = raw_line.strip().split()
  if len(parts) < 4:
    return None
  marker = parts[0]
  if marker not in {"###", "#&", "#!", "#!#"}:
    return None
  return {
    "marker": marker,
    "username": parts[1],
    "expiry": parts[2],
    "credential": parts[3],
    "quota": parts[4] if len(parts) > 4 else "0",
    "iplimit": parts[5] if len(parts) > 5 else "0",
  }


def _read_sidecar_metadata(protocol: str):
  metadata = {}
  path = SIDE_CAR_DB_PATHS[protocol]
  if not path.exists():
    return metadata

  for raw_line in path.read_text(encoding="utf-8", errors="ignore").splitlines():
    parsed = _parse_sidecar_line(raw_line)
    if not parsed:
      continue
    metadata[parsed["username"]] = parsed

  return metadata


def _extract_credential_near(lines, marker_index: int, username: str):
  upper = min(len(lines), marker_index + 12)
  fallback = None

  for idx in range(marker_index + 1, upper):
    line = lines[idx]
    if _parse_account_line(line):
      break

    match = CREDENTIAL_REGEX.search(line)
    if not match:
      continue

    if fallback is None:
      fallback = match.group(1)

    if f'"email":"{username}"' in line or f'"email": "{username}"' in line:
      return match.group(1)

  return fallback


def _collect_accounts_for_sidecar(lines):
  dedup = {}
  for idx, line in enumerate(lines):
    parsed = _parse_account_line(line)
    if not parsed:
      continue
    credential = _extract_credential_near(lines, idx, parsed["username"])
    key = (parsed["protocol_key"], parsed["username"])
    dedup[key] = {
      "protocol_key": parsed["protocol_key"],
      "username": parsed["username"],
      "expiry": parsed["expiry"],
      "credential": credential,
    }

  return sorted(dedup.values(), key=lambda item: (item["protocol_key"], item["username"]))


def _render_sidecar_line(protocol: str, account: dict, metadata: dict):
  username = account["username"]
  existing = metadata.get(username, {})
  credential = account["credential"] or existing.get("credential") or str(uuid.uuid4())

  if protocol == "shadowsocks":
    return f"### {username} {account['expiry']} {credential}\n"

  quota = existing.get("quota", "0") or "0"
  iplimit = existing.get("iplimit", "0") or "0"
  return f"### {username} {account['expiry']} {credential} {quota} {iplimit}\n"


def _sync_sidecar_databases(lines):
  accounts = _collect_accounts_for_sidecar(lines)
  by_protocol = {key: [] for key in SIDE_CAR_DB_PATHS}

  for account in accounts:
    by_protocol[account["protocol_key"]].append(account)

  for protocol, sidecar_path in SIDE_CAR_DB_PATHS.items():
    metadata = _read_sidecar_metadata(protocol)
    rendered_lines = []
    for account in by_protocol[protocol]:
      rendered_lines.append(_render_sidecar_line(protocol, account, metadata))
    _atomic_write_path(sidecar_path, "".join(rendered_lines))


def _mutate_config(mutator):
  lines = _read_config_lines()
  backup_path = _create_backup()
  updated_lines = mutator(list(lines))
  _atomic_write(updated_lines)

  if not _restart_xray():
    shutil.copy2(backup_path, XRAY_CONFIG_PATH)
    _restart_xray()
    raise RuntimeError("Restart xray gagal. Config otomatis dikembalikan dari backup.")

  try:
    _sync_sidecar_databases(_read_config_lines())
  except Exception as exc:
    shutil.copy2(backup_path, XRAY_CONFIG_PATH)
    _restart_xray()
    try:
      _sync_sidecar_databases(_read_config_lines())
    except Exception:
      pass
    raise RuntimeError(
      f"Sinkronisasi sidecar gagal. Config otomatis dikembalikan dari backup. Detail: {exc}"
    ) from exc

  return str(backup_path)


def list_accounts():
  lines = _read_config_lines()
  dedup = {}
  for line in lines:
    parsed = _parse_account_line(line)
    if not parsed:
      continue
    key = (parsed["protocol_key"], parsed["username"])
    dedup[key] = {
      "protocol": parsed["protocol"],
      "protocol_key": parsed["protocol_key"],
      "username": parsed["username"],
      "expiry": parsed["expiry"],
    }

  return sorted(dedup.values(), key=lambda item: (item["protocol"], item["username"]))


def get_account_summary():
  summary = {
    "VMESS": 0,
    "VLESS": 0,
    "TROJAN": 0,
    "SHADOWSOCKS": 0,
    "TOTAL": 0,
  }

  for account in list_accounts():
    summary[account["protocol"]] = summary.get(account["protocol"], 0) + 1
    summary["TOTAL"] += 1

  return summary


def create_account(protocol: str, username: str, expiry_days):
  protocol = protocol.lower()
  _validate_protocol(protocol)
  _validate_username(username)
  days = _normalize_expiry_days(expiry_days)

  rule = PROTOCOL_RULES[protocol]
  marker = rule["marker"]
  expiry = _expiry_from_days(days)
  credential = str(uuid.uuid4())

  def mutator(lines):
    if _username_exists(lines, username):
      raise ValueError("Username sudah terdaftar di config Xray.")

    entry_line = rule["entry_template"].format(credential=credential, username=username)
    insert_lines = [f"{marker} {username} {expiry}\n", f"{entry_line}\n"]

    for anchor in rule["anchors"]:
      anchor_index = _find_anchor_index(lines, anchor)
      lines[anchor_index + 1:anchor_index + 1] = insert_lines

    return lines

  backup_path = _mutate_config(mutator)
  return {
    "protocol": rule["display"],
    "username": username,
    "expiry": expiry,
    "credential": credential,
    "backup_path": backup_path,
  }


def update_account_expiry(protocol: str, username: str, expiry_days):
  protocol = protocol.lower()
  _validate_protocol(protocol)
  _validate_username(username)
  days = _normalize_expiry_days(expiry_days)

  rule = PROTOCOL_RULES[protocol]
  marker = rule["marker"]
  expiry = _expiry_from_days(days)

  def mutator(lines):
    changed = 0
    for idx, line in enumerate(lines):
      parsed = _parse_account_line(line)
      if parsed and parsed["protocol_key"] == protocol and parsed["username"] == username:
        lines[idx] = f"{marker} {username} {expiry}\n"
        changed += 1

    if changed == 0:
      raise ValueError("Akun tidak ditemukan.")

    return lines

  backup_path = _mutate_config(mutator)
  return {
    "protocol": rule["display"],
    "username": username,
    "expiry": expiry,
    "backup_path": backup_path,
  }


def delete_account(protocol: str, username: str):
  protocol = protocol.lower()
  _validate_protocol(protocol)
  _validate_username(username)

  rule = PROTOCOL_RULES[protocol]

  def mutator(lines):
    blocks = []

    for idx, line in enumerate(lines):
      parsed = _parse_account_line(line)
      if not parsed:
        continue
      if parsed["protocol_key"] != protocol or parsed["username"] != username:
        continue

      block_end = None
      for cursor in range(idx + 1, len(lines)):
        if lines[cursor].lstrip().startswith("},{"):
          block_end = cursor
          break

      if block_end is None:
        raise ValueError("Struktur account block tidak valid. Hapus dibatalkan.")

      blocks.append((idx, block_end))

    if not blocks:
      raise ValueError("Akun tidak ditemukan.")

    for start, end in reversed(blocks):
      del lines[start:end + 1]

    return lines

  backup_path = _mutate_config(mutator)
  return {
    "protocol": rule["display"],
    "username": username,
    "backup_path": backup_path,
  }
