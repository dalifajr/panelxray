#!/bin/bash
clear

THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ -r "$THEME_FILE" ]]; then
    . "$THEME_FILE"
fi

panel_user="$(cat /usr/bin/user 2>/dev/null || echo User)"

if declare -F thm_title >/dev/null; then
    thm_title "MENU VMESS"
    thm_welcome "$panel_user"
    thm_menu_item 1 "Buat Akun Vmess WS/GRPC"
    thm_menu_item 2 "Buat Akun Trial Vmess WS/GRPC"
    thm_menu_item 3 "Hapus Akun Vmess WS/GRPC"
    thm_menu_item 4 "Perpanjang Akun Vmess"
    thm_menu_item 5 "Cek Login Akun Vmess"
    thm_menu_item 6 "Lihat Konfigurasi Vmess"
    thm_menu_item 7 "Suspend Akun Vmess"
    thm_menu_item 8 "Aktifkan Kembali Akun Vmess"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU VMESS"
    echo "1) Buat Akun Vmess WS/GRPC"
    echo "2) Buat Akun Trial Vmess WS/GRPC"
    echo "3) Hapus Akun Vmess WS/GRPC"
    echo "4) Perpanjang Akun Vmess"
    echo "5) Cek Login Akun Vmess"
    echo "6) Lihat Konfigurasi Vmess"
    echo "7) Suspend Akun Vmess"
    echo "8) Aktifkan Kembali Akun Vmess"
    echo "0) Kembali Ke Menu Utama"
fi

read -p "Pilih Menu [ 0 - 8 ] : " menu

case $menu in
1) clear; addws ;;
2) clear; trialws ;;
3) clear; delws ;;
4) clear; renewws ;;
5) clear; cekws ;;
6) clear; user-ws ;;
7) clear; suspws ;;
8) clear; unsuspws ;;
0) clear; menu ;;
*) clear; menu ;;
esac
