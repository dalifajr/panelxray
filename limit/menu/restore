#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

# ==========================================
# Color
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
LIGHT='\033[0;37m'
BOT_DB="/etc/bot/.bot.db"
CHATID="$(grep -E '^#bot# ' "$BOT_DB" 2>/dev/null | awk '{print $3}' | head -n 1)"
KEY="$(grep -E '^#bot# ' "$BOT_DB" 2>/dev/null | awk '{print $2}' | head -n 1)"
TIME="10"
URL="https://api.telegram.org/bot$KEY/sendMessage"

clear
if declare -F thm_title >/dev/null; then
    thm_title "RESTORE VPS DATA"
fi

function notif_restore() {
    if [[ -z "$CHATID" || -z "$KEY" ]]; then
        return 0
    fi

    TEXT="
<code>◇━━━━━━━━━━━━━━◇</code>
<b>RESTORE NOTIF</b>
<b>Detail Restore VPS</b>
<code>◇━━━━━━━━━━━━━━◇</code>
<code>Restore Vps Done</code>
<code>◇━━━━━━━━━━━━━━◇</code>
<code>Panel VPS dan Bot Telegram dipulihkan</code>
"

    curl -s --max-time "$TIME" -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" "$URL" >/dev/null 2>&1 || true
}

restore_copy_if_exists() {
    local src="$1"
    local dst="$2"
    if [[ -e "$src" ]]; then
        mkdir -p "$dst"
        cp -r "$src" "$dst"
    fi
}

restore_dir_contents_if_exists() {
    local src_dir="$1"
    local dst_dir="$2"
    if [[ -d "$src_dir" ]]; then
        mkdir -p "$dst_dir"
        cp -r "$src_dir"/. "$dst_dir"/
    fi
}

restore_file_as_if_exists() {
    local src_file="$1"
    local dst_file="$2"
    if [[ -f "$src_file" ]]; then
        mkdir -p "$(dirname "$dst_file")"
        cp -f "$src_file" "$dst_file"
    fi
}

restore_dir_as_if_exists() {
    local src_dir="$1"
    local dst_dir="$2"
    if [[ -d "$src_dir" ]]; then
        mkdir -p "$(dirname "$dst_dir")"
        rm -rf "$dst_dir"
        cp -a "$src_dir" "$dst_dir"
    fi
}

restart_service_if_exists() {
    local unit="$1"
    if systemctl list-unit-files 2>/dev/null | grep -q "^${unit}\.service"; then
        systemctl enable "$unit" >/dev/null 2>&1 || true
        systemctl restart "$unit" >/dev/null 2>&1 || true
    fi
}

# ==========================================
# Getting
clear
CURRENT_DOMAIN=""
if [[ -f /etc/xray/domain ]]; then
    CURRENT_DOMAIN=$(cat /etc/xray/domain)
fi
echo "Silahkan Masukin Link Backupnya"
read -rp "Link File: " -e url
if [[ -z "$url" ]]; then
    echo "Link backup tidak boleh kosong"
    exit 1
fi
echo ""
echo "Pilih opsi restore:"
echo "1. Gabungkan Data (Merge & Skip Duplikat) [Rekomendasi]"
echo "2. Hapus Data Lama & Overwrite (Clean)"
read -rp "Pilihan [1/2, default: 1]: " -e opt_mode
if [[ "$opt_mode" == "2" ]]; then
    RESTORE_MODE="clean"
else
    RESTORE_MODE="merge"
fi
export RESTORE_MODE

if ! wget -q -O /root/backup.zip "$url"; then
    echo "Gagal download file backup"
    exit 1
fi

if ! unzip -o /root/backup.zip -d /root >/dev/null 2>&1; then
    echo "Gagal extract file backup"
    rm -f /root/backup.zip
    exit 1
fi

rm -f /root/backup.zip
sleep 1
echo Start Restore
if [[ ! -d /root/backup ]]; then
    echo "Folder /root/backup tidak ditemukan di dalam arsip"
    exit 1
fi

cd /root/backup
mkdir -p /etc/kyt /usr/local/share/vpnxray /opt

if [[ "$RESTORE_MODE" == "clean" ]]; then
    # Restore data core VPS.
    restore_copy_if_exists passwd /etc/
    restore_copy_if_exists group /etc/
    restore_copy_if_exists shadow /etc/
    restore_copy_if_exists gshadow /etc/
    restore_copy_if_exists kyt /var/lib/
    restore_copy_if_exists xray /etc/
    restore_copy_if_exists html /var/www/
    restore_copy_if_exists crontab /etc/
    restore_copy_if_exists .ssh.db /etc/ssh/
    restore_copy_if_exists .vmess.db /etc/vmess/
    restore_copy_if_exists .vless.db /etc/vless/
    restore_copy_if_exists .trojan.db /etc/trojan/
    restore_copy_if_exists .shadowsocks.db /etc/shadowsocks/
    
    # Restore data limit quota/ip when available in backup package.
    restore_dir_contents_if_exists vmessquota /etc/limit/vmess/
    restore_dir_contents_if_exists vlessquota /etc/limit/vless/
    restore_dir_contents_if_exists trojanquota /etc/limit/trojan/
    restore_dir_contents_if_exists shadowsocksquota /etc/limit/shadowsocks/
    restore_dir_contents_if_exists vmessip /etc/kyt/limit/vmess/ip/
    restore_dir_contents_if_exists vlessip /etc/kyt/limit/vless/ip/
    restore_dir_contents_if_exists trojanip /etc/kyt/limit/trojan/ip/
    restore_dir_contents_if_exists shadowsocksip /etc/kyt/limit/shadowsocks/ip/
    
    # Restore jalur runtime bot Telegram panel (kyt + helper scripts).
    restore_dir_as_if_exists bot-notif /etc/bot
    restore_dir_as_if_exists kyt-bin /usr/bin/kyt
    restore_dir_contents_if_exists bot-scripts /usr/bin/
    restore_file_as_if_exists kyt.service /etc/systemd/system/kyt.service
    
    # Restore jalur panel VPS web + me-cli.
    restore_dir_as_if_exists vpnxray-webpanel /opt/vpnxray-webpanel
    restore_file_as_if_exists webpanel.env /etc/kyt/webpanel.env
    restore_file_as_if_exists webpanel.service /etc/systemd/system/vpnxray-webpanel.service
    restore_file_as_if_exists panel-user /usr/bin/user
    restore_file_as_if_exists panel-password /usr/bin/password
    restore_dir_as_if_exists vpnxray-me-cli-sunset /opt/vpnxray-me-cli-sunset
    restore_dir_as_if_exists me-cli-sunset-main /usr/local/share/vpnxray/me-cli-sunset-main
else
    # Merge mode: compile and execute python merging helper
    cat << 'EOF' > /tmp/merge_restore.py
import os, json, sqlite3, glob

mode = os.environ.get('RESTORE_MODE', 'merge')
backup_dir = '/root/backup'

print("Menjalankan merge restore (skipping duplicates)...")

# 1. Identify duplicates
current_users = set()
if os.path.exists('/etc/passwd'):
    with open('/etc/passwd', 'r') as f:
        for line in f:
            parts = line.strip().split(':')
            if len(parts) >= 3 and int(parts[2]) >= 1000 and parts[0] != 'nobody':
                current_users.add(parts[0].lower())

current_xray_users = set()
xray_config_path = '/etc/xray/config.json'
if os.path.exists(xray_config_path):
    try:
        with open(xray_config_path, 'r') as f:
            cfg = json.load(f)
        for inbound in cfg.get('inbounds', []):
            for client in inbound.get('settings', {}).get('clients', []):
                email = client.get('email', '')
                username = email.split('@')[0] if '@' in email else email
                if username:
                    current_xray_users.add(username.lower())
    except Exception as e:
        pass

duplicates = current_users.union(current_xray_users)
print(f"User duplikat yang terdeteksi dan dilewati: {list(duplicates)}")

# 2. Merge passwd, shadow, group, gshadow
new_passwd = []
new_shadow = []
new_group = []
new_gshadow = []

if os.path.exists(f"{backup_dir}/passwd"):
    with open(f"{backup_dir}/passwd", 'r') as f:
        bak_passwd = f.readlines()
    with open(f"{backup_dir}/shadow", 'r') as f:
        bak_shadow = f.readlines()
    with open(f"{backup_dir}/group", 'r') as f:
        bak_group = f.readlines()
    with open(f"{backup_dir}/gshadow", 'r') as f:
        bak_gshadow = f.readlines()

    for line in bak_passwd:
        parts = line.strip().split(':')
        if len(parts) >= 3:
            username = parts[0]
            uid = int(parts[2])
            if uid >= 1000 and username != 'nobody':
                if username.lower() in duplicates:
                    print(f"Skipping duplicate system user: {username}")
                else:
                    new_passwd.append(line)
                    for s in bak_shadow:
                        if s.startswith(username + ':'):
                            new_shadow.append(s)
                            break
                    for g in bak_group:
                        if g.startswith(username + ':'):
                            new_group.append(g)
                            break
                    for gs in bak_gshadow:
                        if gs.startswith(username + ':'):
                            new_gshadow.append(gs)
                            break

    if new_passwd:
        with open('/etc/passwd', 'a') as f:
            f.writelines(new_passwd)
        with open('/etc/shadow', 'a') as f:
            f.writelines(new_shadow)
        with open('/etc/group', 'a') as f:
            f.writelines(new_group)
        with open('/etc/gshadow', 'a') as f:
            f.writelines(new_gshadow)

# 3. Merge Xray configs
backup_xray_config = f"{backup_dir}/xray/config.json"
if os.path.exists(xray_config_path) and os.path.exists(backup_xray_config):
    try:
        with open(xray_config_path, 'r') as f:
            curr_cfg = json.load(f)
        with open(backup_xray_config, 'r') as f:
            bak_cfg = json.load(f)
            
        curr_clients_by_id = {}
        for inbound in curr_cfg.get('inbounds', []):
            for client in inbound.get('settings', {}).get('clients', []):
                c_id = client.get('id', client.get('password'))
                if c_id:
                    curr_clients_by_id[c_id] = client

        merged_count = 0
        for inbound in bak_cfg.get('inbounds', []):
            protocol = inbound.get('protocol')
            curr_inbound = None
            for ci in curr_cfg.get('inbounds', []):
                if ci.get('protocol') == protocol:
                    curr_inbound = ci
                    break
            if curr_inbound:
                curr_clients = curr_inbound.setdefault('settings', {}).setdefault('clients', [])
                for client in inbound.get('settings', {}).get('clients', []):
                    c_id = client.get('id', client.get('password'))
                    email = client.get('email', '')
                    username = email.split('@')[0] if '@' in email else email
                    if username.lower() not in duplicates and c_id not in curr_clients_by_id:
                        curr_clients.append(client)
                        merged_count += 1
                        
        if merged_count > 0:
            with open(xray_config_path, 'w') as f:
                json.dump(curr_cfg, f, indent=4)
    except Exception as e:
        pass

# 4. Merge bot SQLite database
backup_db = f"{backup_dir}/kyt-bin/database.db"
current_db = "/usr/bin/kyt/database.db"
if os.path.exists(backup_db) and os.path.exists(current_db):
    try:
        c_new = sqlite3.connect(current_db)
        c_old = sqlite3.connect(backup_db)
        c_old.row_factory = sqlite3.Row
        rows = c_old.execute("SELECT * FROM account_registry").fetchall()
        for r in rows:
            username = r['username']
            if username.lower() not in duplicates:
                c_new.execute(
                    "INSERT OR REPLACE INTO account_registry (tg_id, service, category, username, is_trial, created_at, expires_at, active) "
                    "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                    (r['tg_id'], r['service'], r['category'], r['username'], r['is_trial'], r['created_at'], r['expires_at'], r['active'])
                )
        c_new.commit()
        c_new.close()
        c_old.close()
    except Exception as e:
        pass

# 5. Merge webpanel database
backup_laravel_db = f"{backup_dir}/database.sqlite"
current_laravel_db = "/opt/vpnxray-webpanel/database/database.sqlite"
if os.path.exists(backup_laravel_db) and os.path.exists(current_laravel_db):
    try:
        c_new = sqlite3.connect(current_laravel_db)
        c_old = sqlite3.connect(backup_laravel_db)
        c_old.row_factory = sqlite3.Row
        
        # Read from backup
        rows = c_old.execute("SELECT * FROM users").fetchall()
        user_id_map = {}
        for r in rows:
            username = r['username']
            exists = c_new.execute("SELECT id FROM users WHERE username=?", (username,)).fetchone()
            if not exists:
                cur = c_new.execute(
                    "INSERT INTO users (name, username, email, password, role, status, vpn_account_limit, telegram_id, balance, created_at, updated_at) "
                    "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
                    (r['name'], r['username'], r['email'], r['password'], r['role'], r['status'], r['vpn_account_limit'], r['telegram_id'], r['balance'], r['created_at'], r['updated_at'])
                )
                user_id_map[r['id']] = cur.lastrowid
            else:
                user_id_map[r['id']] = exists[0]
                
        # Merge VPN accounts
        vpn_rows = c_old.execute("SELECT * FROM vpn_accounts").fetchall()
        for r in vpn_rows:
            vpn_user = r['vpn_username']
            exists = c_new.execute("SELECT id FROM vpn_accounts WHERE vpn_username=?", (vpn_user,)).fetchone()
            if not exists:
                new_uid = user_id_map.get(r['user_id'])
                if new_uid:
                    c_new.execute(
                        "INSERT INTO vpn_accounts (user_id, vpn_username, service, is_trial, admin_suspended, created_at, updated_at) "
                        "VALUES (?, ?, ?, ?, ?, ?, ?)",
                        (new_uid, r['vpn_username'], r['service'], r['is_trial'], r['admin_suspended'], r['created_at'], r['updated_at'])
                    )
        c_new.commit()
        c_new.close()
        c_old.close()
    except Exception as e:
        pass

# 6. Merge protocol database files (.ssh.db, etc.)
for db_file in glob.glob(f"{backup_dir}/*.db"):
    fname = os.path.basename(db_file)
    target_db = f"/etc/ssh/.{fname}" if fname == 'ssh.db' else f"/etc/{fname.replace('.db','')}/.{fname}"
    if os.path.exists(db_file) and os.path.exists(target_db):
        try:
            with open(target_db, 'r') as f:
                curr_lines = f.readlines()
            with open(db_file, 'r') as f:
                bak_lines = f.readlines()
            existing = {l.split()[1].lower() for l in curr_lines if len(l.split()) >= 2}
            
            append_lines = []
            for line in bak_lines:
                parts = line.strip().split()
                if len(parts) >= 2:
                    username = parts[1]
                    if username.lower() not in duplicates:
                        append_lines.append(line)
            if append_lines:
                with open(target_db, 'a') as f:
                    f.writelines(append_lines)
        except Exception as e:
            pass

# 7. Copy limits and quotas for non-duplicate users
for svc in ['ssh', 'vmess', 'vless', 'trojan', 'shadowsocks']:
    limit_files = glob.glob(f"{backup_dir}/kyt/limit/{svc}/ip/*")
    for f in limit_files:
        user = os.path.basename(f)
        if user.lower() not in duplicates:
            os.makedirs(f"/etc/kyt/limit/{svc}/ip", exist_ok=True)
            os.system(f"cp -f {f} /etc/kyt/limit/{svc}/ip/{user}")
    quota_files = glob.glob(f"{backup_dir}/{svc}quota/*")
    for f in quota_files:
        user = os.path.basename(f)
        if user.lower() not in duplicates:
            os.makedirs(f"/etc/{svc}", exist_ok=True)
            os.system(f"cp -f {f} /etc/{svc}/{user}")

print("Merge completed successfully.")
EOF
    python3 /tmp/merge_restore.py
    rm -f /tmp/merge_restore.py
fi

# Always restore html and openvpn profiles as they have no username conflicts
restore_copy_if_exists html /var/www/
cp /etc/openvpn/*.ovpn /var/www/html/ 2>/dev/null || true

chmod +x /usr/bin/bot-* >/dev/null 2>&1 || true
chmod 600 /usr/bin/user /usr/bin/password /etc/kyt/webpanel.env >/dev/null 2>&1 || true

# Preserve new domain if it was set
if [[ -n "$CURRENT_DOMAIN" ]]; then
    echo "$CURRENT_DOMAIN" > /etc/xray/domain
fi

# Check if domain changed and renew SSL
BACKUP_DOMAIN=""
if [[ -f /root/backup/xray/domain ]]; then
    BACKUP_DOMAIN=$(cat /root/backup/xray/domain)
fi

if [[ -n "$CURRENT_DOMAIN" && -n "$BACKUP_DOMAIN" && "$CURRENT_DOMAIN" != "$BACKUP_DOMAIN" ]]; then
    echo "Domain baru terdeteksi: $CURRENT_DOMAIN (sebelumnya $BACKUP_DOMAIN)"
    echo "Memperbarui sertifikat SSL Let's Encrypt secara otomatis..."
    systemctl stop nginx 2>/dev/null || true
    systemctl stop haproxy 2>/dev/null || true
    if [[ ! -f /root/.acme.sh/acme.sh ]]; then
        mkdir -p /root/.acme.sh
        curl -sS https://acme-install.netlify.app/acme.sh -o /root/.acme.sh/acme.sh >/dev/null 2>&1 || true
        chmod +x /root/.acme.sh/acme.sh
        /root/.acme.sh/acme.sh --upgrade --auto-upgrade >/dev/null 2>&1 || true
        /root/.acme.sh/acme.sh --set-default-ca --server letsencrypt >/dev/null 2>&1 || true
    fi
    if [[ -f /root/.acme.sh/acme.sh ]]; then
        /root/.acme.sh/acme.sh --issue -d "$CURRENT_DOMAIN" --standalone -k ec-256 --force >/dev/null 2>&1 || true
        /root/.acme.sh/acme.sh --installcert -d "$CURRENT_DOMAIN" --fullchainpath /etc/xray/xray.crt --keypath /etc/xray/xray.key --ecc >/dev/null 2>&1 || true
        chmod 777 /etc/xray/xray.key >/dev/null 2>&1 || true
        
        # Compile hap.pem for HAProxy
        if [[ -f /etc/xray/xray.crt && -f /etc/xray/xray.key ]]; then
            mkdir -p /etc/haproxy/certs >/dev/null 2>&1 || true
            cat /etc/xray/xray.crt /etc/xray/xray.key > /etc/haproxy/hap.pem 2>/dev/null || true
            chmod 600 /etc/haproxy/hap.pem >/dev/null 2>&1 || true
            cp -f /etc/haproxy/hap.pem /etc/haproxy/certs/default.pem >/dev/null 2>&1 || true
        fi
    fi
fi

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
    restart_service_if_exists kyt
    restart_service_if_exists vpnxray-webpanel
    restart_service_if_exists xray
    restart_service_if_exists nginx
    restart_service_if_exists haproxy
    restart_service_if_exists ws
fi

notif_restore
rm -rf /root/backup
echo "Restore selesai. Jalur panel VPS dan bot Telegram sudah dipulihkan."
echo ""
if declare -F thm_footer >/dev/null; then
    thm_footer
else
    echo -e "${GREEN}created by dzulfikrialifajri store${NC}"
fi