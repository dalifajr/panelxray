#!/bin/bash
REPO_API="https://api.github.com/repos/dalifajr/panelxray"

green='\e[0;32m'
red='\e[1;31m'
yellow='\e[1;33m'
cyan='\e[1;36m'
NC='\e[0m'

clear
echo -e "${cyan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${yellow}            CEK UPDATE PROGRAM${NC}"
echo -e "${cyan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if ! command -v curl >/dev/null 2>&1; then
  echo -e "${red}curl tidak ditemukan di sistem${NC}"
  read -n 1 -s -r -p "Press any key to back on menu"
  menu
  exit 1
fi

repo_json=$(curl -fsSL "$REPO_API" 2>/dev/null)
if [ -z "$repo_json" ]; then
  echo -e "${red}Gagal mengambil data repository${NC}"
  read -n 1 -s -r -p "Press any key to back on menu"
  menu
  exit 1
fi

default_branch=$(echo "$repo_json" | awk -F '"' '/"default_branch"/ {print $4; exit}')
updated_at=$(echo "$repo_json" | awk -F '"' '/"updated_at"/ {print $4; exit}')
stars=$(echo "$repo_json" | awk -F ': ' '/"stargazers_count"/ {gsub(",","",$2); print $2; exit}')
open_issues=$(echo "$repo_json" | awk -F ': ' '/"open_issues_count"/ {gsub(",","",$2); print $2; exit}')

if [ -z "$default_branch" ]; then
  default_branch="main"
fi

commit_json=$(curl -fsSL "${REPO_API}/commits/${default_branch}" 2>/dev/null)
latest_sha=$(echo "$commit_json" | awk -F '"' '/"sha"/ {print $4; exit}')
commit_date=$(echo "$commit_json" | awk -F '"' '/"date"/ {print $4; exit}')

if [ -d /root/panelxray/.git ] && command -v git >/dev/null 2>&1; then
  local_sha=$(git -C /root/panelxray rev-parse --short HEAD 2>/dev/null)
else
  local_sha="unknown"
fi

echo -e "${green}Repository   :${NC} https://github.com/dalifajr/panelxray"
echo -e "${green}Branch       :${NC} ${default_branch}"
echo -e "${green}Updated At   :${NC} ${updated_at}"
echo -e "${green}Latest SHA   :${NC} ${latest_sha}"
echo -e "${green}Commit Date  :${NC} ${commit_date}"
echo -e "${green}Stars        :${NC} ${stars}"
echo -e "${green}Open Issues  :${NC} ${open_issues}"
echo -e "${green}Local SHA    :${NC} ${local_sha}"

if [ "$local_sha" != "unknown" ] && [ -n "$latest_sha" ]; then
  short_remote=$(echo "$latest_sha" | cut -c1-7)
  if [ "$local_sha" = "$short_remote" ]; then
    echo -e "${green}Status       : Up to date${NC}"
  else
    echo -e "${yellow}Status       : Update available${NC}"
  fi
fi

echo ""
read -n 1 -s -r -p "Press any key to back on menu"
menu
