#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

clear
panel_user="$(cat /usr/bin/user 2>/dev/null)"
[[ -z "$panel_user" ]] && panel_user="User"

if declare -F thm_title >/dev/null; then
  thm_title "TROJAN CONTROL CENTER"
    thm_welcome "$panel_user"
  thm_section "ACCOUNT LIFECYCLE"
    thm_menu_item 1 "Buat Akun XRAY Trojan WS/GRPC"
    thm_menu_item 2 "Buat Akun Trial XRAY Trojan WS/GRPC"
    thm_menu_item 3 "Hapus Akun XRAY Trojan WS/GRPC"
    thm_menu_item 4 "Perpanjang Akun Trojan"
  thm_section "MONITORING & POLICY"
    thm_menu_item 5 "Cek Login Akun Trojan"
    thm_menu_item 6 "Lihat Konfigurasi Trojan"
    thm_menu_item 7 "Suspend Akun Trojan"
    thm_menu_item 8 "Aktifkan Kembali Akun Trojan"
  thm_section "NAVIGATION"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU TROJAN"
    echo "1) Buat Akun XRAY Trojan WS/GRPC"
    echo "2) Buat Akun Trial XRAY Trojan WS/GRPC"
    echo "3) Hapus Akun XRAY Trojan WS/GRPC"
    echo "4) Perpanjang Akun Trojan"
    echo "5) Cek Login Akun Trojan"
    echo "6) Lihat Konfigurasi Trojan"
    echo "7) Suspend Akun Trojan"
    echo "8) Aktifkan Kembali Akun Trojan"
    echo "0) Kembali Ke Menu Utama"
fi

if declare -F thm_prompt >/dev/null; then
  thm_prompt "Pilih Menu [ 0 - 8 ] : "
  read -r menu
else
  read -p "Pilih Menu [ 0 - 8 ] : " menu
fi

case $menu in
1) addtr ;;
2) trialtr ;;
3) deltr ;;
4) renewtr ;;
5) cektr ;;
6) user-tr ;;
7) susptr ;;
8) unsusptr ;;
0) menu ;;
*) menu ;;
esac