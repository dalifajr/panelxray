#!/bin/bash
# Script Setup Laravel Web Panel untuk Xray VPN
# ==========================================
# Pastikan dijalankan sebagai root

if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root" 
   exit 1
fi

echo -e "[\e[32mINFO\e[0m] Memulai instalasi dependensi Web Panel..."

# 1. Install PHP 8.4 & Composer
apt-get update
apt-get install -y software-properties-common curl
add-apt-repository ppa:ondrej/php -y
apt-get update
apt-get install -y php8.4-fpm php8.4-cli php8.4-curl php8.4-mysql php8.4-sqlite3 php8.4-mbstring php8.4-xml php8.4-zip unzip nginx

if ! command -v composer &> /dev/null; then
    curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
fi

# 2. Setup Laravel Project Directory
WEB_DIR="/var/www/webpanel-mvc"
mkdir -p /var/www

echo -e "[\e[32mINFO\e[0m] Mengunduh source code Web Panel terbaru..."
TMP_REPO="/tmp/panelxray-webpanel-setup"
rm -rf $TMP_REPO
git clone https://github.com/dalifajr/panelxray.git $TMP_REPO

if [ -d "$TMP_REPO/limit/webpanel-mvc" ]; then
    rm -rf /var/www/webpanel-mvc
    cp -r $TMP_REPO/limit/webpanel-mvc /var/www/
    rm -rf $TMP_REPO
else
    echo -e "[\e[31mERROR\e[0m] Gagal mengunduh source code Web Panel."
    exit 1
fi

cd $WEB_DIR

echo -e "[\e[32mINFO\e[0m] Menjalankan Composer Install..."
composer install --no-dev --optimize-autoloader

# Setup .env
if [ ! -f .env ]; then
    cp .env.example .env
    php artisan key:generate
    sed -i 's/APP_ENV=local/APP_ENV=production/' .env
    sed -i 's/APP_DEBUG=true/APP_DEBUG=false/' .env
fi

# Auto-detect Telegram Bot Username
BOT_USERNAME="vpnxray_bot"
if [ -f "/usr/bin/kyt/var.txt" ]; then
    BOT_TOKEN=$(grep -E "^BOT_TOKEN=" /usr/bin/kyt/var.txt | cut -d"'" -f2 | cut -d'"' -f2)
    if [ -n "$BOT_TOKEN" ]; then
        BOT_INFO=$(curl -s "https://api.telegram.org/bot${BOT_TOKEN}/getMe")
        EXTRACTED_USERNAME=$(echo "$BOT_INFO" | grep -o '"username":"[^"]*' | cut -d'"' -f4)
        if [ -n "$EXTRACTED_USERNAME" ]; then
            BOT_USERNAME="$EXTRACTED_USERNAME"
            echo -e "[\e[32mINFO\e[0m] Mendeteksi Bot Telegram: @$BOT_USERNAME"
        fi
    fi
fi
grep -q "^TELEGRAM_BOT_USERNAME=" .env && sed -i "s/^TELEGRAM_BOT_USERNAME=.*/TELEGRAM_BOT_USERNAME=${BOT_USERNAME}/" .env || echo "TELEGRAM_BOT_USERNAME=${BOT_USERNAME}" >> .env

# Setup Database SQLite
touch database/database.sqlite
php artisan migrate --force

# Fix Permissions
chown -R www-data:www-data $WEB_DIR
chmod -R 775 $WEB_DIR/storage
chmod -R 775 $WEB_DIR/bootstrap/cache

# Install VPN Bridge Service
echo -e "[\e[32mINFO\e[0m] Menginstal VPN Bridge Service..."
if [ -f "$WEB_DIR/setup-vpn-bridge.sh" ]; then
    cd $WEB_DIR
    bash setup-vpn-bridge.sh
fi

# 3. Setup Nginx Configuration (Integrate with Xray)
DOMAIN=$(cat /etc/xray/domain)
XRAY_CONF="/etc/nginx/conf.d/xray.conf"

if [ -f "$XRAY_CONF" ]; then
    # Hapus default nginx site bawaan instalasi baru dan config usang
    rm -f /etc/nginx/sites-enabled/default
    rm -f /etc/nginx/sites-available/default
    rm -f /etc/nginx/conf.d/webpanel.conf

    # Tulis script python ke temporary file untuk menghindari masalah escaping Bash
    cat << 'EOF' > /tmp/update_nginx.py
import re
import sys

path = sys.argv[1]
try:
    with open(path, 'r') as f:
        config = f.read()

    # Bersihkan block konfigurasi rusak dari percobaan sebelumnya
    broken_pattern = r'\s*index index\.php index\.html;\s*location / \{\s*try_files \\ \\/ /index\.php\?\\;\s*\}\s*location ~ \\\.php\$ \{\s*include fastcgi_params;\s*fastcgi_pass unix:/var/run/php/php8\.4-fpm\.sock;\s*fastcgi_param SCRIPT_FILENAME \\;\s*\}'
    config = re.sub(broken_pattern, '', config)
    
    broken_pattern_83 = r'\s*index index\.php index\.html;\s*location / \{\s*try_files \\ \\/ /index\.php\?\\;\s*\}\s*location ~ \\\.php\$ \{\s*include fastcgi_params;\s*fastcgi_pass unix:/var/run/php/php8\.3-fpm\.sock;\s*fastcgi_param SCRIPT_FILENAME \\;\s*\}'
    config = re.sub(broken_pattern_83, '', config)

    # Ganti root di port 81 (mendukung variasi spasi)
    config = re.sub(r'root\s+/(var/www/html|etc/kyt/limit/webpanel-mvc/public);', 'root /var/www/webpanel-mvc/public;', config)

    php_block = r"""    index index.php index.html;
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
    }"""

    # Tambahkan block PHP di port 81 jika belum ada
    if r'location ~ \.php$' not in config:
        config = re.sub(r'(root\s+/var/www/webpanel-mvc/public;)', lambda m: m.group(1) + '\n' + php_block, config)
        
    # Perbaiki Port 1013 (HTTP/2 Fallback dari Xray) yang selama ini menyebabkan Error 403 di browser
    if 'listen 1013' in config:
        port_1013_block = config.split('listen 1013', 1)[1]
        if 'root /var/www/webpanel-mvc/public;' not in port_1013_block:
            # Sisipkan root dan php_block setelah listen 1013
            config = re.sub(r'(listen\s+1013\s+http2\s+proxy_protocol.*?;)', r'\1\n    root /var/www/webpanel-mvc/public;\n' + php_block, config, count=1)

    with open(path, 'w') as f:
        f.write(config)
except Exception as e:
    print('Failed to update nginx conf:', e)
    sys.exit(1)
EOF

    python3 /tmp/update_nginx.py "$XRAY_CONF"
    rm -f /tmp/update_nginx.py
fi

# Fix PHP-FPM Systemd restriction (karena Laravel berada di /etc yang di-mount read-only oleh php-fpm)
mkdir -p /etc/systemd/system/php8.4-fpm.service.d
cat > /etc/systemd/system/php8.4-fpm.service.d/override.conf <<EOF
[Service]
ReadWritePaths=$WEB_DIR/storage $WEB_DIR/bootstrap/cache $WEB_DIR/database
EOF
systemctl daemon-reload

systemctl restart nginx
systemctl restart php8.4-fpm

echo -e "[\e[32mINFO\e[0m] Web Panel berhasil diinstal! Akses langsung melalui https://$DOMAIN"
echo -e "[\e[32mINFO\e[0m] Pastikan Bot Telegram Anda sedang berjalan untuk proses otentikasi."


echo "" 
read -n 1 -s -r -p "Press any key to back on menu"
echo ""
menu
