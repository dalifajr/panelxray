#!/bin/bash
clear

THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ -r "$THEME_FILE" ]]; then
    . "$THEME_FILE"
fi

panel_user="$(cat /usr/bin/user 2>/dev/null || echo User)"

if declare -F thm_title >/dev/null; then
    thm_title "MENU SHADOWSOCKS"
    thm_welcome "$panel_user"
    thm_menu_item 1 "Buat Akun Shadowsocks WS/GRPC"
    thm_menu_item 2 "Buat Akun Trial Shadowsocks WS/GRPC"
    thm_menu_item 3 "Hapus Akun Shadowsocks WS/GRPC"
    thm_menu_item 4 "Perpanjang Akun Shadowsocks"
    thm_menu_item 5 "Cek Login Akun Shadowsocks"
    thm_menu_item 6 "Lihat Konfigurasi Shadowsocks"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU SHADOWSOCKS"
    echo "1) Buat Akun Shadowsocks WS/GRPC"
    echo "2) Buat Akun Trial Shadowsocks WS/GRPC"
    echo "3) Hapus Akun Shadowsocks WS/GRPC"
    echo "4) Perpanjang Akun Shadowsocks"
    echo "5) Cek Login Akun Shadowsocks"
    echo "6) Lihat Konfigurasi Shadowsocks"
    echo "0) Kembali Ke Menu Utama"
fi

read -p "Pilih Menu [ 0 - 6 ] : " menu
case $menu in
1) addss ;;
2) trialss ;;
3) delss ;;
4) renewss ;;
5) cekss ;;
6) user-ss ;;
0) menu ;;
*) menu ;;
esac
