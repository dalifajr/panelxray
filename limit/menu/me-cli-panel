#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

set -euo pipefail

APP_DIR="/opt/vpnxray-me-cli-sunset"
INSTALLER="/usr/local/sbin/install-me-cli"
KYT_VAR_FILE="/usr/bin/kyt/var.txt"
VENV_PY="${APP_DIR}/.venv/bin/python"

is_valid_runtime_install() {
  local required_files=(
    "${APP_DIR}/requirements.txt"
    "${APP_DIR}/main.py"
    "${APP_DIR}/panel.sh"
    "${APP_DIR}/telegram_main.py"
    "${APP_DIR}/app/service/auth.py"
    "${APP_DIR}/app/service/decoy.py"
    "${APP_DIR}/hot_data/hot.json"
    "${APP_DIR}/hot_data/hot2.json"
    "${APP_DIR}/decoy_data/decoy-default-balance.json"
    "${APP_DIR}/decoy_data/decoy-default-qris.json"
    "${VENV_PY}"
  )
  local required_dirs=(
    "${APP_DIR}/app"
    "${APP_DIR}/app/client"
    "${APP_DIR}/app/menus"
    "${APP_DIR}/app/service"
    "${APP_DIR}/app/bot_handlers"
    "${APP_DIR}/hot_data"
    "${APP_DIR}/decoy_data"
  )
  local item

  for item in "${required_dirs[@]}"; do
    [[ -d "$item" ]] || return 1
  done

  for item in "${required_files[@]}"; do
    [[ -f "$item" ]] || return 1
  done

  return 0
}

resolve_installer() {
  local candidate
  local installer_candidates=(
    "$INSTALLER"
    "/usr/bin/install-me-cli"
  )

  for candidate in "${installer_candidates[@]}"; do
    if [[ -f "$candidate" ]]; then
      printf '%s' "$candidate"
      return 0
    fi
  done

  candidate="$(command -v install-me-cli 2>/dev/null || true)"
  if [[ -n "$candidate" ]]; then
    printf '%s' "$candidate"
    return 0
  fi

  return 1
}

run_installer() {
  local installer_path
  installer_path="$(resolve_installer || true)"

  if [[ -z "$installer_path" ]]; then
    echo "Installer tidak ditemukan: $INSTALLER"
    return 1
  fi

  if [[ -x "$installer_path" ]]; then
    "$installer_path"
  else
    bash "$installer_path"
  fi
}

read_kv() {
  local file="$1"
  local key="$2"
  local line
  local value

  [[ -f "$file" ]] || return 0
  line="$(grep -E "^[[:space:]]*${key}[[:space:]]*=" "$file" | tail -n 1 || true)"
  [[ -n "$line" ]] || return 0

  value="${line#*=}"
  value="$(printf '%s' "$value" | tr -d '\r')"
  value="$(printf '%s' "$value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  value="${value%\"}"
  value="${value#\"}"
  value="${value%\'}"
  value="${value#\'}"
  printf '%s' "$value"
}

ensure_non_conflicting_bot_token() {
  local me_token
  local kyt_token

  me_token="$(read_kv "$APP_DIR/.env" "TELEGRAM_BOT_TOKEN" || true)"
  kyt_token="$(read_kv "$KYT_VAR_FILE" "BOT_TOKEN" || true)"

  if [[ -z "$me_token" || "$me_token" == "your_bot_token_here" ]]; then
    echo "TELEGRAM_BOT_TOKEN belum valid di $APP_DIR/.env"
    return 1
  fi

  if [[ -n "$kyt_token" && "$me_token" == "$kyt_token" ]]; then
    echo "Token Telegram me-cli sama dengan token bot panel vpnxray (kyt)."
    echo "Ganti TELEGRAM_BOT_TOKEN di $APP_DIR/.env agar dua bot tidak bentrok."
    return 1
  fi

  return 0
}

open_panel() {
  cd "$APP_DIR"
  bash "$APP_DIR/panel.sh"
}

offer_install() {
  local reason="${1:-}"

  clear
  echo "MYnyak Engsel (me-cli) belum siap dijalankan."
  if [[ -n "$reason" ]]; then
    echo "$reason"
  fi

  if [[ -t 0 ]]; then
    read -rp "Install sekarang? [Y/n]: " ans
    if [[ "$ans" =~ ^[Nn]$ ]]; then
      return 1
    fi
  fi

  run_installer
  return 0
}

main() {
  if ! is_valid_runtime_install; then
    if ! offer_install "Instalasi me-cli terdeteksi tidak lengkap (subfolder/subservice hilang atau venv belum siap)."; then
      command -v menu >/dev/null 2>&1 && menu
      exit 0
    fi
  fi

  if ! is_valid_runtime_install; then
    echo "Panel me-cli belum lengkap setelah proses instalasi/repair."
    echo "Jalankan ulang installer: /usr/local/sbin/install-me-cli"
    exit 1
  fi

  if ! ensure_non_conflicting_bot_token; then
    echo "Panel tetap dibuka. Perbaiki TELEGRAM_BOT_TOKEN jika ingin start bot Telegram tanpa bentrok."
    sleep 2
  fi

  if ! open_panel; then
    echo "Panel me-cli gagal dijalankan. Jalankan installer ulang: /usr/local/sbin/install-me-cli"
    exit 1
  fi
  command -v menu >/dev/null 2>&1 && menu
}

main "$@"