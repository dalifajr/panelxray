#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

set -euo pipefail

APP_DIR="/opt/vpnxray-me-cli-sunset"
INSTALLER="/usr/local/sbin/install-me-cli"
KYT_VAR_FILE="/usr/bin/kyt/var.txt"

read_kv() {
  local file="$1"
  local key="$2"
  local line
  local value

  [[ -f "$file" ]] || return 0
  line="$(grep -E "^[[:space:]]*${key}[[:space:]]*=" "$file" | tail -n 1 || true)"
  [[ -n "$line" ]] || return 0

  value="${line#*=}"
  value="$(printf '%s' "$value" | tr -d '\r')"
  value="$(printf '%s' "$value" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  value="${value%\"}"
  value="${value#\"}"
  value="${value%\'}"
  value="${value#\'}"
  printf '%s' "$value"
}

ensure_non_conflicting_bot_token() {
  local me_token
  local kyt_token

  me_token="$(read_kv "$APP_DIR/.env" "TELEGRAM_BOT_TOKEN" || true)"
  kyt_token="$(read_kv "$KYT_VAR_FILE" "BOT_TOKEN" || true)"

  if [[ -z "$me_token" || "$me_token" == "your_bot_token_here" ]]; then
    echo "TELEGRAM_BOT_TOKEN belum valid di $APP_DIR/.env"
    return 1
  fi

  if [[ -n "$kyt_token" && "$me_token" == "$kyt_token" ]]; then
    echo "Token Telegram me-cli sama dengan token bot panel vpnxray (kyt)."
    echo "Ganti TELEGRAM_BOT_TOKEN di $APP_DIR/.env agar dua bot tidak bentrok."
    return 1
  fi

  return 0
}

open_panel() {
  cd "$APP_DIR"
  bash "$APP_DIR/panel.sh"
}

offer_install() {
  clear
  echo "MYnyak Engsel (me-cli) belum terpasang."
  if [[ ! -x "$INSTALLER" ]]; then
    echo "Installer tidak ditemukan: $INSTALLER"
    return 1
  fi

  if [[ -t 0 ]]; then
    read -rp "Install sekarang? [y/N]: " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      return 1
    fi
  fi

  "$INSTALLER"
  return 0
}

main() {
  if [[ ! -x "$APP_DIR/panel.sh" ]]; then
    if ! offer_install; then
      command -v menu >/dev/null 2>&1 && menu
      exit 0
    fi
  fi

  if [[ ! -x "$APP_DIR/panel.sh" ]]; then
    echo "Panel me-cli tidak ditemukan setelah proses instalasi."
    exit 1
  fi

  if ! ensure_non_conflicting_bot_token; then
    command -v menu >/dev/null 2>&1 && menu
    exit 0
  fi

  open_panel || true
  command -v menu >/dev/null 2>&1 && menu
}

main "$@"