#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

clear
panel_user="$(cat /usr/bin/user 2>/dev/null)"
[[ -z "$panel_user" ]] && panel_user="User"

if declare -F thm_title >/dev/null; then
  thm_title "VLESS CONTROL CENTER"
    thm_welcome "$panel_user"
  thm_section "ACCOUNT LIFECYCLE"
    thm_menu_item 1 "Buat Akun XRAY Vless WS/GRPC"
    thm_menu_item 2 "Buat Akun Trial XRAY Vless WS/GRPC"
    thm_menu_item 3 "Hapus Akun XRAY Vless WS/GRPC"
    thm_menu_item 4 "Perpanjang Akun Vless"
  thm_section "MONITORING & POLICY"
    thm_menu_item 5 "Cek Login Akun Vless"
    thm_menu_item 6 "Lihat Konfigurasi Vless"
    thm_menu_item 7 "Suspend Akun Vless"
    thm_menu_item 8 "Aktifkan Kembali Akun Vless"
  thm_section "NAVIGATION"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU VLESS"
    echo "1) Buat Akun XRAY Vless WS/GRPC"
    echo "2) Buat Akun Trial XRAY Vless WS/GRPC"
    echo "3) Hapus Akun XRAY Vless WS/GRPC"
    echo "4) Perpanjang Akun Vless"
    echo "5) Cek Login Akun Vless"
    echo "6) Lihat Konfigurasi Vless"
    echo "7) Suspend Akun Vless"
    echo "8) Aktifkan Kembali Akun Vless"
    echo "0) Kembali Ke Menu Utama"
fi

if declare -F thm_prompt >/dev/null; then
  thm_prompt "Pilih Menu [ 0 - 8 ] : "
  read -r menu
else
  read -p "Pilih Menu [ 0 - 8 ] : " menu
fi

case $menu in
1) clear; addvless ;;
2) clear; trialvless ;;
3) clear; delvless ;;
4) clear; renewvless ;;
5) clear; cekvless ;;
6) clear; user-vless ;;
7) clear; suspvless ;;
8) clear; unsuspvless ;;
0) clear; menu ;;
*) clear; menu ;;
esac