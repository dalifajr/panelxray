url_encode() {
  local s="$1"
  local out=""
  local i c
  for ((i = 0; i < ${#s}; i++)); do
    c="${s:$i:1}"
    case "$c" in
      [a-zA-Z0-9.~_-]) out+="$c" ;;
      *) out+="$(printf '%%%02X' "'${c}")" ;;
    esac
  done
  echo "$out"
}

QR_READY=-1
ensure_qrencode() {
  if [[ "$QR_READY" -eq 1 ]]; then
    return 0
  fi
  if command -v qrencode >/dev/null 2>&1; then
    QR_READY=1
    return 0
  fi
  if command -v apt-get >/dev/null 2>&1; then
    apt-get update -y >/dev/null 2>&1 || true
    apt-get install -y qrencode >/dev/null 2>&1 || true
  fi
  if command -v qrencode >/dev/null 2>&1; then
    QR_READY=1
    return 0
  fi
  QR_READY=0
  return 1
}

print_terminal_qr() {
  local label="$1"
  local payload="$2"
  echo -e "\033[1;93m---------------------------------------------------\033[0m"
  echo -e " QR ${label}"
  echo -e "\033[1;93m---------------------------------------------------\033[0m"
  if ensure_qrencode; then
    qrencode -t UTF8 -m 1 -s 1 "$payload"
  else
    echo "qrencode tidak tersedia. Install manual: apt-get update -y && apt-get install -y qrencode"
  fi
}

