#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

NC='\033[0m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'

service_state() {
  local svc="$1"
  if systemctl is-active --quiet "$svc" 2>/dev/null; then
    echo -e "${GREEN}RUNNING${NC}"
  elif systemctl list-unit-files 2>/dev/null | grep -q "^${svc}\\.service"; then
    echo -e "${RED}DOWN${NC}"
  else
    echo -e "${YELLOW}NOT INSTALLED${NC}"
  fi
}

clear
if declare -F thm_title >/dev/null; then
  thm_title "SERVICE STATUS"
  thm_info_row "nginx" "$(service_state nginx)"
  thm_info_row "xray" "$(service_state xray)"
  thm_info_row "haproxy" "$(service_state haproxy)"
  thm_info_row "ws" "$(service_state ws)"
  thm_info_row "dropbear" "$(service_state dropbear)"
  thm_info_row "openvpn" "$(service_state openvpn)"
  thm_info_row "fail2ban" "$(service_state fail2ban)"
  thm_info_row "cron" "$(service_state cron)"
  thm_footer
else
  echo -e "SERVICE STATUS"
  echo -e "nginx    : $(service_state nginx)"
  echo -e "xray     : $(service_state xray)"
  echo -e "haproxy  : $(service_state haproxy)"
  echo -e "ws       : $(service_state ws)"
  echo -e "dropbear : $(service_state dropbear)"
  echo -e "openvpn  : $(service_state openvpn)"
  echo -e "fail2ban : $(service_state fail2ban)"
  echo -e "cron     : $(service_state cron)"
fi

echo
read -n 1 -s -r -p "Press any key to back on menu"
menu
