#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

clear

green='\033[0;32m'
red='\033[0;31m'
NC='\033[0m'

MYIP="$(curl -sS ipv4.icanhazip.com)"
LICENSE_URL_PRIMARY="https://raw.githubusercontent.com/dalifajr/panelxray/main/kunci"
LICENSE_URL_FALLBACK="https://raw.githubusercontent.com/nishikazekazata/izin/main/ip"

get_license_line() {
  local line
  line="$(curl -sS "$LICENSE_URL_PRIMARY" | awk -v ip="$MYIP" '$1==ip {print; exit}')"
  if [[ -z "$line" ]]; then
    line="$(curl -sS "$LICENSE_URL_FALLBACK" | awk -v ip="$MYIP" '$1==ip {print; exit}')"
  fi
  echo "$line"
}

license_line="$(get_license_line)"
username="$(echo "$license_line" | awk '{print $2}')"
expiry_date="$(echo "$license_line" | awk '{print $3}')"
[[ -z "$username" ]] && username="User"
[[ -z "$expiry_date" ]] && expiry_date="Unknown"

today="$(date +"%Y-%m-%d")"
status_script="ACTIVE"
days_left="Unknown"
if [[ "$expiry_date" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
  d1=$(date -d "$expiry_date" +%s 2>/dev/null || echo 0)
  d2=$(date -d "$today" +%s 2>/dev/null || echo 0)
  if [[ "$d1" -gt 0 && "$d2" -gt 0 ]]; then
    days_left=$(((d1 - d2) / 86400))
    if [[ "$days_left" -lt 0 ]]; then
      status_script="EXPIRED"
    fi
  fi
fi

model="$(awk -F= '/^PRETTY_NAME=/{gsub(/"/,"",$2);print $2}' /etc/os-release 2>/dev/null)"
[[ -z "$model" ]] && model="Unknown"
core="$(grep -c '^processor' /proc/cpuinfo 2>/dev/null)"
[[ -z "$core" ]] && core="0"
ram_total="$(free -m | awk 'NR==2{print $2}')"
ram_used="$(free -m | awk 'NR==2{print $3}')"
load_cpu="$(top -bn1 | awk '/Cpu\(s\)|%Cpu/{print int(100-$8) "%"; exit}')"
[[ -z "$load_cpu" ]] && load_cpu="0%"
date_vps="$(date +'%d-%m-%Y')"
time_vps="$(date +'%H:%M:%S')"
uptime_vps="$(uptime -p | sed 's/^up //')"
ip_vps="$(curl -s ipinfo.io/ip)"
domain="$(cat /etc/xray/domain 2>/dev/null)"
[[ -z "$domain" ]] && domain="-"
isp="$(cat /etc/xray/isp 2>/dev/null)"
[[ -z "$isp" ]] && isp="-"
city="$(cat /etc/xray/city 2>/dev/null)"
[[ -z "$city" ]] && city="-"

service_flag() {
  local svc="$1"
  if systemctl is-active --quiet "$svc" 2>/dev/null; then
    echo "ON"
  else
    echo "OFF"
  fi
}

status_ssh="$(service_flag ssh)"
if [[ "$status_ssh" == "OFF" ]]; then
  status_ssh="$(service_flag sshd)"
fi
status_ws="$(service_flag ws)"
status_udp="$(service_flag udp-mini-2)"
status_nginx="$(service_flag nginx)"
status_xray="$(service_flag xray)"
status_haproxy="$(service_flag haproxy)"
status_dropbear="$(service_flag dropbear)"

ssh_count="$(awk -F: '$3>=1000 && $1!="nobody" {c++} END{print c+0}' /etc/passwd 2>/dev/null)"
vmess_count="$(grep -c -E '^### ' /etc/xray/config.json 2>/dev/null)"
vmess_count=$((vmess_count / 2))
vless_count="$(grep -c -E '^#& ' /etc/xray/config.json 2>/dev/null)"
vless_count=$((vless_count / 2))
trojan_count="$(grep -c -E '^#! ' /etc/xray/config.json 2>/dev/null)"
trojan_count=$((trojan_count / 2))
shadow_count="$(grep -c -E '^#!# ' /etc/xray/config.json 2>/dev/null)"
shadow_count=$((shadow_count / 2))

thm_title "WELCOME TO PANELXRAY"
thm_welcome "$username"

thm_section "SYSTEM SUMMARY"
thm_info_row "SYSTEM OS" "$model"
thm_info_row "SYSTEM CORE" "$core"
thm_info_row "SERVER RAM" "$ram_used / $ram_total MB"
thm_info_row "LOAD CPU" "$load_cpu"
thm_info_row "DATE" "$date_vps"
thm_info_row "TIME" "$time_vps"
thm_info_row "UPTIME" "$uptime_vps"
thm_info_row "IP VPS" "$ip_vps"
thm_info_row "DOMAIN" "$domain"
thm_info_row "ISP/CITY" "$isp / $city"

thm_section "INFORMATION ACCOUNT"
thm_info_row "SSH/OPENVPN/UDP" "$ssh_count"
thm_info_row "VMESS/WS/GRPC" "$vmess_count"
thm_info_row "VLESS/WS/GRPC" "$vless_count"
thm_info_row "TROJAN/WS/GRPC" "$trojan_count"
thm_info_row "SHADOW/WS/GRPC" "$shadow_count"

thm_section "SERVICE STATUS"
thm_status_row "SSH" "$status_ssh"
thm_status_row "WS-EPRO" "$status_ws"
thm_status_row "UDP CUSTOM" "$status_udp"
thm_status_row "NGINX" "$status_nginx"
thm_status_row "XRAY" "$status_xray"
thm_status_row "HAPROXY" "$status_haproxy"
thm_status_row "DROPBEAR" "$status_dropbear"

thm_section "MENU NAVIGATION"
thm_menu_item 1 "SSH MENU"
thm_menu_item 2 "VMESS MENU"
thm_menu_item 3 "VLESS MENU"
thm_menu_item 4 "TROJAN MENU"
thm_menu_item 5 "SHADOWSOCKS MENU"
thm_menu_item 6 "UTILITY MENU"
thm_menu_item 7 "CHECK BANDWIDTH"
thm_menu_item 8 "SPEEDTEST"
thm_menu_item 9 "LIMIT SPEED"
thm_menu_item 10 "BACKUP/RESTORE"
thm_menu_item 11 "ON/OFF LIMIT IP"
thm_menu_item 12 "MENU BOT"
thm_menu_item 13 "UNINSTALL PANEL"
thm_menu_item 14 "UPDATE PROGRAM"
thm_menu_item 15 "STATUS SERVICE"

thm_section "SCRIPT INFO"
thm_info_row "CLIENT" "$username"
thm_info_row "STATUS SCRIPT" "$status_script"
thm_info_row "EXPIRED DATE" "$expiry_date"
thm_info_row "DAYS LEFT" "$days_left"

thm_footer
echo
read -rp "Options [ 1 - 15 ] >>> " opt
echo

case "$opt" in
1) clear ; m-sshws ;;
2) clear ; m-vmess ;;
3) clear ; m-vless ;;
4) clear ; m-trojan ;;
5) clear ; m-ssws ;;
6) clear ; utility ;;
7) clear ; bw ;;
8) clear ; speedtest ;;
9) clear ; limitspeed ;;
10) clear ; menu-backup ;;
11) clear ; onoff ;;
12) clear ; add-bot-panel ;;
13) clear ; uninstall-panel ;;
14) clear ; cek-update ;;
15) clear ; cek-service ;;
*) clear ; menu ;;
esac