#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

clear

if declare -F thm_title >/dev/null; then
    thm_title "MENU SSH & OPENVPN"
    thm_welcome "$panel_user"
    thm_menu_item 1 "Buat Akun SSH & OpenVPN"
    thm_menu_item 2 "Buat Akun Trial SSH & OpenVPN"
    thm_menu_item 3 "Perpanjang Akun SSH & OpenVPN"
    thm_menu_item 4 "Cek Login Pengguna SSH & OpenVPN"
    thm_menu_item 5 "Daftar Pengguna SSH & OpenVPN"
    thm_menu_item 6 "Hapus Akun SSH & OpenVPN"
    thm_menu_item 7 "Hapus Pengguna Expired"
    thm_menu_item 8 "Atur Auto Kill SSH"
    thm_menu_item 9 "Cek Multi Login SSH"
    thm_menu_item 10 "Lihat Konfigurasi SSH"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU SSH & OPENVPN"
    echo "1) Buat Akun SSH & OpenVPN"
    echo "2) Buat Akun Trial SSH & OpenVPN"
    echo "3) Perpanjang Akun SSH & OpenVPN"
    echo "4) Cek Login Pengguna SSH & OpenVPN"
    echo "5) Daftar Pengguna SSH & OpenVPN"
    echo "6) Hapus Akun SSH & OpenVPN"
    echo "7) Hapus Pengguna Expired"
    echo "8) Atur Auto Kill SSH"
    echo "9) Cek Multi Login SSH"
    echo "10) Lihat Konfigurasi SSH"
    echo "0) Kembali Ke Menu Utama"
fi

read -p "Pilih Menu [ 0 - 10 ] : " menu
echo

case $menu in
1) addssh ;;
2) trial ;;
3) renewssh ;;
4) cekssh ;;
5) member ;;
6) delssh ;;
7) delexp ;;
8) autokill ;;
9) ceklim ;;
10) user-ssh ;;
0) menu ;;
*) menu ;;
esac