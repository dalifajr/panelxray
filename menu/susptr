#!/bin/bash
SERVICE="trojan"
STATE_DIR="/etc/kyt/suspended/${SERVICE}"
CONFIG="/etc/xray/config.json"
DB_FILE="/etc/trojan/.trojan.db"

user=""
reason="manual"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --user)
      user="$2"
      shift 2
      ;;
    --reason)
      reason="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [[ -z "$user" ]]; then
  clear
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " Suspend Trojan Account"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  grep -E "^#! " "$CONFIG" | cut -d ' ' -f 2-3 | column -t | sort | uniq
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  read -rp "Input Username : " user
fi

user="$(echo "$user" | tr -d '\r' | xargs)"

[[ -z "$user" ]] && exit 0
mkdir -p "$STATE_DIR"
if [[ -f "$STATE_DIR/$user" ]]; then
  echo "User already suspended"
  exit 1
fi

exp=$(grep -wE "^#! $user " "$CONFIG" | awk '{print $3}' | head -n1)
uuid=$(grep -wE "^### $user " "$DB_FILE" | awk '{print $4}' | head -n1)

if [[ -z "$uuid" ]]; then
  uuid=$(awk -v u="$user" '
    index($0, "\"email\": \"" u "\"") {
      if (match($0, /"password": *"[^"]+"/)) {
        v = substr($0, RSTART, RLENGTH)
        sub(/.*"password": *"/, "", v)
        sub(/"$/, "", v)
        print v
        exit
      }
    }
  ' "$CONFIG")
fi

if [[ -z "$exp" || -z "$uuid" ]]; then
  echo "User not found"
  exit 1
fi

sed -i "/^#! $user $exp/,/^},{/d" "$CONFIG"
printf '%s %s %s\n' "$exp" "$uuid" "$reason" > "$STATE_DIR/$user"
systemctl restart xray >/dev/null 2>&1

echo "Trojan account suspended: $user"
