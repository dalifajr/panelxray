#!/bin/bash
# Script Setup Laravel Web Panel untuk Xray VPN
# ==========================================
# Pastikan dijalankan sebagai root

if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root" 
   exit 1
fi

echo -e "[\e[32mINFO\e[0m] Memulai instalasi dependensi Web Panel..."

# 1. Install PHP 8.4 & Composer
apt-get update
apt-get install -y software-properties-common curl
add-apt-repository ppa:ondrej/php -y
apt-get update
apt-get install -y php8.4-fpm php8.4-cli php8.4-curl php8.4-mysql php8.4-sqlite3 php8.4-mbstring php8.4-xml php8.4-zip unzip nginx

if ! command -v composer &> /dev/null; then
    curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
fi

# 2. Setup Laravel Project Directory
WEB_DIR="/etc/kyt/limit/webpanel-mvc"
mkdir -p /etc/kyt/limit
if [ -d "/root/vpnxray-main/limit/webpanel-mvc" ]; then
    cp -r /root/vpnxray-main/limit/webpanel-mvc /etc/kyt/limit/
fi

cd $WEB_DIR

echo -e "[\e[32mINFO\e[0m] Menjalankan Composer Install..."
composer install --no-dev --optimize-autoloader

# Setup .env
if [ ! -f .env ]; then
    cp .env.example .env
    php artisan key:generate
    sed -i 's/APP_ENV=local/APP_ENV=production/' .env
    sed -i 's/APP_DEBUG=true/APP_DEBUG=false/' .env
fi

# Setup Database SQLite
touch database/database.sqlite
php artisan migrate --force

# Fix Permissions
chown -R www-data:www-data $WEB_DIR
chmod -R 775 $WEB_DIR/storage
chmod -R 775 $WEB_DIR/bootstrap/cache

# 3. Setup Nginx Configuration (Integrate with Xray)
DOMAIN=$(cat /etc/xray/domain)
XRAY_CONF="/etc/nginx/conf.d/xray.conf"

if [ -f "$XRAY_CONF" ]; then
    # Ubah root direktori pada block listen 81
    sed -i "s|root /var/www/html;|root $WEB_DIR/public;|g" "$XRAY_CONF"
    
    # Tambahkan konfigurasi PHP ke dalam blok server listen 81 jika belum ada
    if ! grep -q "location ~ \\.php\$" "$XRAY_CONF"; then
        awk -v text="    index index.php index.html;\n    location / {\n        try_files \$uri \$uri/ /index.php?\$query_string;\n    }\n    location ~ \\\\.php$ {\n        include fastcgi_params;\n        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;\n        fastcgi_param SCRIPT_FILENAME \$realpath_root\$fastcgi_script_name;\n    }" '1; /root \/etc\/kyt\/limit\/webpanel-mvc\/public;/ {print text}' "$XRAY_CONF" > "${XRAY_CONF}.tmp" && mv "${XRAY_CONF}.tmp" "$XRAY_CONF"
    fi
fi

systemctl restart nginx
systemctl restart php8.4-fpm

echo -e "[\e[32mINFO\e[0m] Web Panel berhasil diinstal! Akses langsung melalui https://$DOMAIN"
echo -e "[\e[32mINFO\e[0m] Pastikan Bot Telegram Anda sedang berjalan untuk proses otentikasi."


echo "" 
read -n 1 -s -r -p "Press any key to back on menu"
echo ""
menu
