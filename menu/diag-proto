#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

NC='\033[0m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'

PASS_COUNT=0
FAIL_COUNT=0
LAST_HTTP_CODE=000
LOCAL_EDGE_IP="127.0.0.1"
TLS_LOCAL_TARGET="127.0.0.1"

report() {
  local proto="$1"
  local stage="$2"
  local ok="$3"
  local detail="$4"
  if [[ "$ok" -eq 1 ]]; then
    echo -e "${GREEN}[PASS]${NC} ${proto} | ${stage} | ${detail}"
    PASS_COUNT=$((PASS_COUNT + 1))
  else
    echo -e "${RED}[FAIL]${NC} ${proto} | ${stage} | ${detail}"
    FAIL_COUNT=$((FAIL_COUNT + 1))
  fi
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

is_listening() {
  local port="$1"
  ss -lnt 2>/dev/null | awk '{print $4}' | grep -E "[:.]${port}$" >/dev/null 2>&1
}

detect_local_edge_ip() {
  local ip
  ip="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++){if($i=="src"){print $(i+1); exit}}}')"
  if [[ -n "$ip" ]]; then
    LOCAL_EDGE_IP="$ip"
  fi
}

probe_tls_public() {
  echo | openssl s_client -connect "${DOMAIN}:443" -servername "${DOMAIN}" -alpn h2,http/1.1 -brief >/dev/null 2>&1
}

probe_tls_local() {
  echo | openssl s_client -connect "${TLS_LOCAL_TARGET}:443" -servername "${DOMAIN}" -alpn h2,http/1.1 -brief >/dev/null 2>&1
}

http_code_from_curl() {
  local out code
  out="$($@ 2>/dev/null || true)"
  code="${out: -3}"
  if [[ "$code" =~ ^[0-9]{3}$ ]]; then
    echo "$code"
  else
    echo "000"
  fi
}

probe_ws_path() {
  local path="$1"
  local code
  code="$(http_code_from_curl curl -k -sS --max-time 8 --http1.1 \
    -H "Host: ${DOMAIN}" \
    -H "Upgrade: websocket" \
    -H "Connection: Upgrade" \
    -o /dev/null -w "%{http_code}" "https://${DOMAIN}${path}")"
  LAST_HTTP_CODE="$code"

  case "$code" in
    101|200|301|302|400|401|403|404|426)
      return 0
      ;;
    *)
      code="$(http_code_from_curl curl -k -sS --max-time 8 --http1.1 \
        --resolve "${DOMAIN}:443:127.0.0.1" \
        -H "Host: ${DOMAIN}" \
        -H "Upgrade: websocket" \
        -H "Connection: Upgrade" \
        -o /dev/null -w "%{http_code}" "https://${DOMAIN}${path}")"
      LAST_HTTP_CODE="$code"
      case "$code" in
        101|200|301|302|400|401|403|404|426)
          return 0
          ;;
        *)
          code="$(http_code_from_curl curl -k -sS --max-time 8 --http1.1 \
            --resolve "${DOMAIN}:443:${LOCAL_EDGE_IP}" \
            -H "Host: ${DOMAIN}" \
            -H "Upgrade: websocket" \
            -H "Connection: Upgrade" \
            -o /dev/null -w "%{http_code}" "https://${DOMAIN}${path}")"
          LAST_HTTP_CODE="$code"
          case "$code" in
            101|200|301|302|400|401|403|404|426)
              return 0
              ;;
            *)
              return 1
              ;;
          esac
          ;;
      esac
      ;;
  esac
}

probe_grpc_path() {
  local path="$1"
  local code
  code="$(http_code_from_curl curl -k -sS --max-time 8 --http2 \
    -H "Host: ${DOMAIN}" \
    -o /dev/null -w "%{http_code}" "https://${DOMAIN}${path}")"
  LAST_HTTP_CODE="$code"

  case "$code" in
    200|204|400|401|403|404|405|415|421|426)
      return 0
      ;;
    *)
      code="$(http_code_from_curl curl -k -sS --max-time 8 --http2 \
        --resolve "${DOMAIN}:443:127.0.0.1" \
        -H "Host: ${DOMAIN}" \
        -o /dev/null -w "%{http_code}" "https://${DOMAIN}${path}")"
      LAST_HTTP_CODE="$code"
      case "$code" in
        200|204|400|401|403|404|405|415|421|426)
          return 0
          ;;
        *)
          code="$(http_code_from_curl curl -k -sS --max-time 8 --http2 \
            --resolve "${DOMAIN}:443:${LOCAL_EDGE_IP}" \
            -H "Host: ${DOMAIN}" \
            -o /dev/null -w "%{http_code}" "https://${DOMAIN}${path}")"
          LAST_HTTP_CODE="$code"
          case "$code" in
            200|204|400|401|403|404|405|415|421|426)
              return 0
              ;;
            *)
              return 1
              ;;
          esac
          ;;
      esac
      ;;
  esac
}

check_service() {
  local svc="$1"
  if systemctl is-active --quiet "$svc" 2>/dev/null; then
    return 0
  fi
  return 1
}

normalize_legacy_http2_directive() {
  local conf_file="/etc/nginx/conf.d/xray.conf"
  [[ -f "$conf_file" ]] || return 0

  # Compat for older nginx: replace "http2 on;" with listen-level http2 flag.
  sed -i 's/listen 81 ssl reuseport;/listen 81 ssl http2 reuseport;/g' "$conf_file" 2>/dev/null || true
  sed -i 's/listen 1013 proxy_protocol so_keepalive=on reuseport;/listen 1013 http2 proxy_protocol so_keepalive=on reuseport;/g' "$conf_file" 2>/dev/null || true
  sed -i '/^\s*http2 on;\s*$/d' "$conf_file" 2>/dev/null || true
}

attempt_self_heal() {
  local need_heal="$1"
  if [[ "$need_heal" -ne 1 ]]; then
    return 0
  fi

  echo -e "${YELLOW}Auto-repair: mencoba memulihkan stack (xray/nginx/haproxy/ws)...${NC}"
  normalize_legacy_http2_directive

  if has_cmd nginx; then
    if ! nginx -t >/tmp/diag-nginx-test.log 2>&1; then
      echo -e "${RED}[WARN]${NC} nginx -t gagal, cek /tmp/diag-nginx-test.log"
    fi
  fi

  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl restart xray >/dev/null 2>&1 || true
  systemctl restart nginx >/dev/null 2>&1 || true
  systemctl restart haproxy >/dev/null 2>&1 || true
  systemctl restart ws >/dev/null 2>&1 || true
  sleep 2
}

clear
if declare -F thm_title >/dev/null; then
  thm_title "DIAGNOSA KONEKSI PROTOKOL XRAY"
else
  echo -e "${BLUE}=== DIAGNOSA KONEKSI PROTOKOL XRAY ===${NC}"
fi

DOMAIN="$(cat /etc/xray/domain 2>/dev/null || true)"
if [[ -z "$DOMAIN" ]]; then
  DOMAIN="$(cat /root/domain 2>/dev/null || true)"
fi
if [[ -z "$DOMAIN" ]]; then
  read -rp "Domain tidak ditemukan otomatis, masukkan domain: " DOMAIN
fi

if [[ -z "$DOMAIN" ]]; then
  echo -e "${RED}Domain kosong, diagnosa dibatalkan.${NC}"
  read -n 1 -s -r -p "Tekan tombol apa saja untuk kembali"
  utility
  exit 1
fi

echo -e "Domain target: ${YELLOW}${DOMAIN}${NC}"
detect_local_edge_ip
echo -e "Local edge IP: ${YELLOW}${LOCAL_EDGE_IP}${NC}"
echo

for cmd in curl openssl ss systemctl; do
  if has_cmd "$cmd"; then
    report "SYSTEM" "Dependency" 1 "$cmd tersedia"
  else
    report "SYSTEM" "Dependency" 0 "$cmd tidak tersedia"
  fi
done

echo
HAPROXY_ACTIVE=0
NGINX_ACTIVE=0
XRAY_ACTIVE=0

if check_service haproxy; then
  HAPROXY_ACTIVE=1
  report "SYSTEM" "Service" 1 "haproxy active"
else
  report "SYSTEM" "Service" 0 "haproxy inactive"
fi
if check_service nginx; then
  NGINX_ACTIVE=1
  report "SYSTEM" "Service" 1 "nginx active"
else
  report "SYSTEM" "Service" 0 "nginx inactive"
fi
if check_service xray; then
  XRAY_ACTIVE=1
  report "SYSTEM" "Service" 1 "xray active"
else
  report "SYSTEM" "Service" 0 "xray inactive"
fi

echo
P443_LISTEN=0
P1010_LISTEN=0
P1013_LISTEN=0

if is_listening 443; then
  P443_LISTEN=1
  report "SYSTEM" "Edge Port" 1 "443 listening"
else
  report "SYSTEM" "Edge Port" 0 "443 not listening"
fi
if is_listening 1010; then
  P1010_LISTEN=1
  report "SYSTEM" "Bridge Port" 1 "1010 listening"
else
  report "SYSTEM" "Bridge Port" 0 "1010 not listening"
fi
if is_listening 1013; then
  P1013_LISTEN=1
  report "SYSTEM" "Bridge Port" 1 "1013 listening"
else
  report "SYSTEM" "Bridge Port" 0 "1013 not listening"
fi

NEED_HEAL=0
if [[ "$NGINX_ACTIVE" -eq 0 || "$P1010_LISTEN" -eq 0 || "$P1013_LISTEN" -eq 0 ]]; then
  NEED_HEAL=1
fi
attempt_self_heal "$NEED_HEAL"

if [[ "$NEED_HEAL" -eq 1 ]]; then
  echo
  echo -e "${BLUE}=== VERIFIKASI PASCA AUTO-REPAIR ===${NC}"

  if check_service haproxy; then
    report "SYSTEM" "Service(recheck)" 1 "haproxy active"
  else
    report "SYSTEM" "Service(recheck)" 0 "haproxy inactive"
  fi
  if check_service nginx; then
    report "SYSTEM" "Service(recheck)" 1 "nginx active"
  else
    report "SYSTEM" "Service(recheck)" 0 "nginx inactive"
  fi
  if check_service xray; then
    report "SYSTEM" "Service(recheck)" 1 "xray active"
  else
    report "SYSTEM" "Service(recheck)" 0 "xray inactive"
  fi

  if is_listening 1010; then
    report "SYSTEM" "Bridge Port(recheck)" 1 "1010 listening"
  else
    report "SYSTEM" "Bridge Port(recheck)" 0 "1010 not listening"
  fi
  if is_listening 1013; then
    report "SYSTEM" "Bridge Port(recheck)" 1 "1013 listening"
  else
    report "SYSTEM" "Bridge Port(recheck)" 0 "1013 not listening"
  fi
fi

TLS_PUBLIC_OK=0
if probe_tls_public; then
  TLS_PUBLIC_OK=1
fi
report "SYSTEM" "TLS Handshake Public" "$TLS_PUBLIC_OK" "${DOMAIN}:443"

TLS_LOCAL_OK=0
TLS_LOCAL_TARGET="127.0.0.1"
if probe_tls_local; then
  TLS_LOCAL_OK=1
else
  TLS_LOCAL_TARGET="$LOCAL_EDGE_IP"
  if probe_tls_local; then
    TLS_LOCAL_OK=1
  fi
fi
report "SYSTEM" "TLS Handshake Local" "$TLS_LOCAL_OK" "${TLS_LOCAL_TARGET}:443 (SNI ${DOMAIN})"

echo

diag_protocol() {
  local proto="$1"
  local ws_path="$2"
  local grpc_path="$3"
  local ws_port="$4"
  local grpc_port="$5"

  local ws_edge=0
  local grpc_edge=0
  local ws_inbound=0
  local grpc_inbound=0

  if probe_ws_path "$ws_path"; then
    ws_edge=1
  fi
  report "$proto" "Edge->WS Path" "$ws_edge" "https://${DOMAIN}${ws_path} [HTTP:${LAST_HTTP_CODE}]"

  if probe_grpc_path "$grpc_path"; then
    grpc_edge=1
  fi
  report "$proto" "Edge->gRPC Path" "$grpc_edge" "https://${DOMAIN}${grpc_path} [HTTP:${LAST_HTTP_CODE}]"

  if is_listening "$ws_port"; then
    ws_inbound=1
  fi
  report "$proto" "Inbound WS Port" "$ws_inbound" "127.0.0.1:${ws_port}"

  if is_listening "$grpc_port"; then
    grpc_inbound=1
  fi
  report "$proto" "Inbound gRPC Port" "$grpc_inbound" "127.0.0.1:${grpc_port}"

  local protocol_ok=0
  if [[ "$ws_edge" -eq 1 && "$grpc_edge" -eq 1 && "$ws_inbound" -eq 1 && "$grpc_inbound" -eq 1 ]]; then
    protocol_ok=1
  fi

  report "$proto" "Protocol Summary" "$protocol_ok" "WS+gRPC edge/path/inbound"
  echo
}

diag_protocol "VLESS" "/vless" "/vless-grpc" 10001 10005
diag_protocol "VMESS" "/vmess" "/vmess-grpc" 10002 10006
diag_protocol "TROJAN" "/trojan-ws" "/trojan-grpc" 10003 10007
diag_protocol "SHADOWSOCKS" "/ss-ws" "/ss-grpc" 10004 10008

echo "========================================"
echo -e "Total PASS : ${GREEN}${PASS_COUNT}${NC}"
echo -e "Total FAIL : ${RED}${FAIL_COUNT}${NC}"
if [[ "$FAIL_COUNT" -eq 0 ]]; then
  echo -e "HASIL AKHIR: ${GREEN}SEMUA UJI LULUS${NC}"
else
  echo -e "HASIL AKHIR: ${RED}ADA TITIK PUTUS (cek baris FAIL)${NC}"
fi
echo "========================================"
echo

echo "Catatan:"
echo "- Jika TLS Public FAIL tapi TLS Local PASS, fokus di DNS/Cloudflare/NAT publik."
echo "- Jika Edge path FAIL tapi Inbound PASS, fokus di HAProxy/Nginx/path ACL."
echo "- Auto-repair dijalankan saat nginx/bridge port bermasalah (lihat blok recheck)."
echo "- Jika Inbound FAIL, fokus di Xray inbound/proses xray."
echo "- Jika TLS Public dan Local sama-sama FAIL, fokus di certificate/haproxy bind 443."
echo "- Jika HTTP code 000, biasanya timeout/reset (network/firewall/edge)."

echo
read -n 1 -s -r -p "Tekan tombol apa saja untuk kembali ke menu"
utility
