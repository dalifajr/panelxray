#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

clear

RED='\033[0;31m'
YELLOW='\033[0;33m'

LIMIT_SERVICES=(vmip vlip trip ssip sship)

service_running() {
    systemctl is-active --quiet "$1"
}

limit_status_label() {
    local active=0
    local total=${#LIMIT_SERVICES[@]}
    local svc

    for svc in "${LIMIT_SERVICES[@]}"; do
        if service_running "$svc"; then
            active=$((active + 1))
        fi
    done

    if [[ "$active" -eq "$total" ]]; then
        echo "${GREEN}AKTIF${NC}"
    elif [[ "$active" -gt 0 ]]; then
        echo "${YELLOW}SEBAGIAN AKTIF (${active}/${total})${NC}"
    else
        echo "${RED}TIDAK AKTIF${NC}"
    fi
}

create_limit_service() {
    local unit_name="$1"
    local mode="$2"

    cat >"/etc/systemd/system/${unit_name}.service" << EOF
[Unit]
Description=VPNXray Limit Monitor (${mode})
After=network.target

[Service]
WorkingDirectory=/root
ExecStart=/usr/bin/limit-ip ${mode}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
}

enable_limit_services() {
    create_limit_service vmip vmip
    create_limit_service vlip vlip
    create_limit_service trip trip
    create_limit_service ssip ssip
    create_limit_service sship sship

    systemctl daemon-reload
    for svc in "${LIMIT_SERVICES[@]}"; do
        systemctl enable "$svc" >/dev/null 2>&1
        systemctl restart "$svc" >/dev/null 2>&1
    done
}

disable_limit_services() {
    local svc
    for svc in "${LIMIT_SERVICES[@]}"; do
        systemctl stop "$svc" >/dev/null 2>&1
        systemctl disable "$svc" >/dev/null 2>&1
        rm -f "/etc/systemd/system/${svc}.service"
    done
    systemctl daemon-reload
}

status_udp1="$(limit_status_label)"

if declare -F thm_title >/dev/null; then
    thm_title "MENU LIMIT IP"
    thm_info_row "Status Limit IP" "$status_udp1"
    thm_menu_item 1 "Nonaktifkan Limit IP"
    thm_menu_item 2 "Aktifkan Limit IP"
    thm_menu_item 0 "Kembali Ke Menu Utama"
    thm_footer
else
    echo "MENU LIMIT IP"
    echo "Status Limit IP: $status_udp1"
    echo "1) Nonaktifkan Limit IP"
    echo "2) Aktifkan Limit IP"
    echo "0) Kembali Ke Menu Utama"
fi

read -p "Pilih Menu [ 1 - 2 atau 0 ] : " menu
case $menu in
1)   clear ;
    disable_limit_services
    reboot
    ;;
2) clear ;
    enable_limit_services
    reboot
    ;;
0) clear ;
    menu
    ;;
*) clear ;
    menu
    ;;
esac