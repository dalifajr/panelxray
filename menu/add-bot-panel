run_kyt_installer() {
  local tmp_script
  run_installer_candidate() {
    "$@"
    if systemctl is-active --quiet kyt; then
      return 0
    fi

    echo -e "${RED}Service kyt masih gagal setelah instalasi.${NC}"
    echo -e "${yell}Log terbaru kyt:${NC}"
    journalctl -u kyt -n 40 --no-pager || true
    return 1
  }

  if [[ -x /usr/local/sbin/kyt.sh ]]; then
    run_installer_candidate /usr/local/sbin/kyt.sh
    return
  fi

  if command -v kyt.sh >/dev/null 2>&1; then
    run_installer_candidate kyt.sh
    return
  fi

  if [[ -r /usr/local/sbin/scripts/maintenance/kyt.sh ]]; then
    run_installer_candidate bash /usr/local/sbin/scripts/maintenance/kyt.sh
    return
  fi

  if [[ -r /root/kyt.sh ]]; then
    run_installer_candidate bash /root/kyt.sh
    return
  fi

  tmp_script="/tmp/kyt-maintenance.sh"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL https://raw.githubusercontent.com/dalifajr/panelxray/main/scripts/maintenance/kyt.sh -o "$tmp_script"
  else
    wget -qO "$tmp_script" https://raw.githubusercontent.com/dalifajr/panelxray/main/scripts/maintenance/kyt.sh
  fi

  if [[ -s "$tmp_script" ]]; then
    chmod +x "$tmp_script"
    run_installer_candidate bash "$tmp_script"
    rm -f "$tmp_script"
    return
  fi

  echo -e "${RED}Installer bot tidak ditemukan.${NC}"
  echo -e "${yell}Jalankan update menu lalu coba lagi.${NC}"
  read -n 1 -s -r -p "Tekan tombol apa saja untuk kembali"
}

