#!/bin/bash
THEME_FILE="$(dirname "$0")/_theme.sh"
if [[ ! -r "$THEME_FILE" && -r /usr/local/sbin/_theme.sh ]]; then
  THEME_FILE="/usr/local/sbin/_theme.sh"
fi
if [[ -r "$THEME_FILE" ]]; then
  . "$THEME_FILE"
fi

set -euo pipefail

REPO_URL="https://github.com/dalifajr/panelxray.git"
REPO_API="https://api.github.com/repos/dalifajr/panelxray"
TARGET_SBIN="/usr/local/sbin"
STATE_FILE="/etc/kyt/panelxray-revision"
TMP_DIR="/tmp/panelxray-menu-update.$$"
BRANCH="${PANELXRAY_BRANCH:-}"

green='\e[0;32m'
red='\e[1;31m'
yellow='\e[1;33m'
cyan='\e[1;36m'
NC='\e[0m'

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

clear
echo -e "${cyan}==========================================================${NC}"
echo -e "${yellow}                 UPDATE PROGRAM (GITHUB)                  ${NC}"
echo -e "${cyan}==========================================================${NC}"

if ! command -v git >/dev/null 2>&1; then
  echo -e "${red}Git tidak ditemukan. Install git terlebih dahulu.${NC}"
  read -n 1 -s -r -p "Press any key to back on menu"
  menu
  exit 1
fi

if [ -z "$BRANCH" ]; then
  BRANCH="$(curl -fsSL "$REPO_API" 2>/dev/null | awk -F '"' '/"default_branch"/ {print $4; exit}')"
  [ -n "$BRANCH" ] || BRANCH="main"
fi

echo -e "${green}Target Branch:${NC} $BRANCH"

if ! git clone --depth 1 --branch "$BRANCH" "$REPO_URL" "$TMP_DIR" >/dev/null 2>&1; then
  echo -e "${red}Gagal clone branch $BRANCH dari repository.${NC}"
  read -n 1 -s -r -p "Press any key to back on menu"
  menu
  exit 1
fi

if [ ! -d "$TMP_DIR/limit/menu" ]; then
  echo -e "${red}Struktur repository tidak valid: limit/menu tidak ditemukan.${NC}"
  read -n 1 -s -r -p "Press any key to back on menu"
  menu
  exit 1
fi

old_sha="unknown"
[ -f "$STATE_FILE" ] && old_sha="$(cat "$STATE_FILE" 2>/dev/null || echo unknown)"
new_sha="$(git -C "$TMP_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"

mkdir -p "$TARGET_SBIN" /etc/kyt
cp -rf "$TMP_DIR/limit/menu/." "$TARGET_SBIN/"
chmod +x "$TARGET_SBIN"/* 2>/dev/null || true
echo "$new_sha" > "$STATE_FILE"

echo -e "${green}Update selesai.${NC}"
echo -e "${green}Old revision:${NC} $old_sha"
echo -e "${green}New revision:${NC} $new_sha"
echo -e "${green}Target path :${NC} $TARGET_SBIN"

echo ""
read -n 1 -s -r -p "Press any key to back on menu"
menu